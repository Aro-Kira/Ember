        }
        lines {
          text: "    name: \'David Miller\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    timeAgo: \'1h ago\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    type: \'DEVOTIONAL\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    content: \'\"Morning reflection on Psalm 23. Even when things feel dark, there\\\'s always a path forward. I wanted to share this with anyone else who\\\'s feeling a bit lost this week. Remember that He restores our souls and guides our paths.\"\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    status: \'pending\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
