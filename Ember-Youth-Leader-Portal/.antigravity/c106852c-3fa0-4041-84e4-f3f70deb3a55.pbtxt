        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'pr3\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'FRIENDSHIP\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
