    instruction: "Update base styles, custom scrollbars, glass panels, and keyframe animations in index.css for the Elegant Dark theme"
    replacement_infos {
      original_chunk {
        target_content: "/* Custom styles for high-fidelity interactive elements */\n@layer base {\n  body {\n    background-color: #0b1326;\n    color: #dae2fd;\n    font-family: var(--font-sans);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n}\n\n/* Custom Scrollbars */\n.custom-scrollbar::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-track {\n  background: #131b2e;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb {\n  background: #2d3449;\n  border-radius: 9999px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\n  background: #f59e0b;\n}\n\n/* Glass panel */\n.glass-panel {\n  background: rgba(30, 41, 59, 0.4);\n  backdrop-filter: blur(12px);\n  border: 1px solid rgba(83, 68, 52, 0.4);\n}\n\n.glass-card {\n  background: #1e293b;\n  border: 1px solid #334155;\n  transition: all 0.3s ease;\n}\n\n.glass-card:hover {\n  border-color: #f59e0b;\n  box-shadow: 0 0 15px rgba(245, 158, 11, 0.05);\n}\n\n/* Scanner scanning line animation */\n@keyframes scan {\n  0% { top: 10%; opacity: 0; }\n  50% { opacity: 1; }\n  100% { top: 90%; opacity: 0; }\n}\n\n.scanner-line {\n  animation: scan 2.5s linear infinite;\n}\n\n/* Success Pulse for scanner active state */\n@keyframes success-pulse {\n  0%, 100% { border-color: #4ade80; box-shadow: 0 0 10px rgba(74, 222, 128, 0.2); }\n  50% { border-color: #166534; box-shadow: 0 0 0px rgba(74, 222, 128, 0); }\n}\n\n.success-pulse {\n  animation: success-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n}\n\n/* Pulse animation for scanner targeting brackets */\n@keyframes scan-bracket {\n  0%, 100% { border-color: rgba(245, 158, 11, 0.8); }\n  50% { border-color: rgba(245, 158, 11, 0.3); }\n}\n\n.scan-bracket-pulse {\n  animation: scan-bracket 1.5s ease-in-out infinite;\n}"
        replacement_content: "/* Custom styles for high-fidelity interactive elements */\n@layer base {\n  body {\n    background-color: #09090b;\n    color: #f4f4f5;\n    font-family: var(--font-sans);\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n  }\n}\n\n/* Custom Scrollbars */\n.custom-scrollbar::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-track {\n  background: #111113;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb {\n  background: #27272a;\n  border-radius: 9999px;\n}\n\n.custom-scrollbar::-webkit-scrollbar-thumb:hover {\n  background: #10b981;\n}\n\n/* Glass panel */\n.glass-panel {\n  background: rgba(24, 24, 27, 0.75);\n  backdrop-filter: blur(12px);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.glass-card {\n  background: #18181b;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  transition: all 0.3s ease;\n}\n\n.glass-card:hover {\n  border-color: #10b981;\n  box-shadow: 0 0 15px rgba(16, 185, 129, 0.05);\n}\n\n/* Scanner scanning line animation */\n@keyframes scan {\n  0% { top: 10%; opacity: 0; }\n  50% { opacity: 1; }\n  100% { top: 90%; opacity: 0; }\n}\n\n.scanner-line {\n  animation: scan 2.5s linear infinite;\n}\n\n/* Success Pulse for scanner active state */\n@keyframes success-pulse {\n  0%, 100% { border-color: #10b981; box-shadow: 0 0 10px rgba(16, 185, 129, 0.2); }\n  50% { border-color: #064e3b; box-shadow: 0 0 0px rgba(16, 185, 129, 0); }\n}\n\n.success-pulse {\n  animation: success-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n}\n\n/* Pulse animation for scanner targeting brackets */\n@keyframes scan-bracket {\n  0%, 100% { border-color: rgba(16, 185, 129, 0.8); }\n  50% { border-color: rgba(16, 185, 129, 0.3); }\n}\n\n.scan-bracket-pulse {\n  animation: scan-bracket 1.5s ease-in-out infinite;\n}"
      }
      num_matches: 1
    }
  }
}
