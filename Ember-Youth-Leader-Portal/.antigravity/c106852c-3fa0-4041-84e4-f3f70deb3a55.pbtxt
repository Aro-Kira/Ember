        lines {
          text: "export const INITIAL_SUBMISSIONS: ModerationSubmission[] = ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'sub1\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Sarah J.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    timeAgo: \'20m ago\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    type: \'TESTIMONY\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    content: \'\"I was really struggling with my exams last week, feeling totally overwhelmed. During youth group on Wednesday, the message about \\\'Peace that surpasses understanding\\\' really hit home. I\\\'ve been feeling so much lighter since then and wanted to thank the leaders for praying with me!\"\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    status: \'pending\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
