        lines {
          text: "    category: \'FAMILY\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'\"Praying for my parents as they navigate some tough health issues recently. Hoping for strength and swift healing.\"\',"
