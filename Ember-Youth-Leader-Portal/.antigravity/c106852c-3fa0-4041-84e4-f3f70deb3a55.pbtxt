    replacement_chunks {
      replacement_content: "import { useState } from \'react\';\nimport { \n  Gavel, \n  Heart, \n  Check, \n  X, \n  ArrowRight, \n  CheckCircle, \n  ShieldAlert, \n  Database, \n  Cpu, \n  Lock, \n  Filter, \n  Plus,\n  Flame\n} from \'lucide-react\';\nimport { ModerationSubmission, PrayerItem } from \'../types\';\n\ninterface ModerationHubProps {\n  submissions: ModerationSubmission[];\n  prayerItems: PrayerItem[];\n  onApproveSubmission: (id: string) => void;\n  onRejectSubmission: (id: string) => void;\n  onUpdatePrayerStage: (id: string, stage: \'new\' | \'active\' | \'archived\') => void;\n  onAddPrayerItem: (item: Omit<PrayerItem, \'id\' | \'prayingCount\'>) => void;\n}\n\nexport default function ModerationHub({\n  submissions,\n  prayerItems,\n  onApproveSubmission,\n  onRejectSubmission,\n  onUpdatePrayerStage,\n  onAddPrayerItem\n}: ModerationHubProps) {\n  const [subTab, setSubTab] = useState<\'pending\' | \'published\' | \'rejected\'>(\'pending\');\n  const [showAddPrayer, setShowAddPrayer] = useState(false);\n  const [newPrayerCategory, setNewPrayerCategory] = useState(\'STUDIES\');\n  const [newPrayerText, setNewPrayerText] = useState(\'\');\n  const [newPrayerAuthor, setNewPrayerAuthor] = useState(\'Anonymous\');\n\n  const handleAddPrayer = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newPrayerText) {\n      alert(\'Please enter your prayer request content.\');\n      return;\n    }\n\n    onAddPrayerItem({\n      category: newPrayerCategory.toUpperCase(),\n      text: `\"${newPrayerText}\"`,\n      author: newPrayerAuthor || \'Anonymous\',\n      stage: \'new\'\n    });\n\n    setNewPrayerText(\'\');\n    setNewPrayerAuthor(\'Anonymous\');\n    setShowAddPrayer(false);\n    alert(\'Prayer request registered in the \"New Queue\".\');\n  };\n\n  const pendingSubs = submissions.filter(s => s.status === \'pending\');\n  const approvedSubs = submissions.filter(s => s.status === \'approved\');\n  const rejectedSubs = submissions.filter(s => s.status === \'rejected\');\n\n  const newPrayers = prayerItems.filter(p => p.stage === \'new\');\n  const activePrayers = prayerItems.filter(p => p.stage === \'active\');\n  const archivedPrayers = prayerItems.filter(p => p.stage === \'archived\');\n\n  return (\n    <div className=\"space-y-6\">\n      {/* Workspace Header & Sub Tabs */}\n      <div className=\"flex flex-col gap-4\">\n        <div className=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-outline-variant/30 pb-4\">\n          <div>\n            <span className=\"font-mono text-xs text-primary uppercase tracking-[0.2em] mb-1 block\">Workflow Center</span>\n            <h3 className=\"font-sans text-xl font-bold text-on-surface\">Queue &amp; Prayer Management</h3>\n          </div>\n          \n          <button \n            onClick={() => setShowAddPrayer(true)}\n            className=\"bg-primary hover:bg-primary-fixed-dim text-on-primary font-bold px-5 py-2.5 rounded-lg text-xs flex items-center gap-1.5 transition-all active:scale-95 shadow-lg shadow-primary/10 cursor-pointer\"\n          >\n            <Plus className=\"w-4 h-4 text-on-primary\" /> Create Prayer Request\n          </button>\n        </div>\n\n        {/* Sub-Navigation Tabs */}\n        <div className=\"flex border-b border-outline-variant gap-6 font-sans\">\n          <button \n            onClick={() => setSubTab(\'pending\')}\n            className={`pb-3 px-1 text-xs font-bold flex items-center gap-2 transition-all relative cursor-pointer ${\n              subTab === \'pending\' ? \'text-primary\' : \'text-on-surface-variant hover:text-on-surface\'\n            }`}\n          >\n            Pending Queue <span className=\"bg-primary/20 text-primary text-[10px] px-2 py-0.5 rounded-full font-mono\">{pendingSubs.length}</span>\n            {subTab === \'pending\' && <span className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-primary rounded-full\" />}\n          </button>\n          <button \n            onClick={() => setSubTab(\'published\')}\n            className={`pb-3 px-1 text-xs font-bold flex items-center gap-2 transition-all relative cursor-pointer ${\n              subTab === \'published\' ? \'text-primary\' : \'text-on-surface-variant hover:text-on-surface\'\n            }`}\n          >\n            Published Archive <span className=\"bg-emerald-500/10 text-emerald-400 text-[10px] px-2 py-0.5 rounded-full font-mono\">{approvedSubs.length}</span>\n            {subTab === \'published\' && <span className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-primary rounded-full\" />}\n          </button>\n          <button \n            onClick={() => setSubTab(\'rejected\')}\n            className={`pb-3 px-1 text-xs font-bold flex items-center gap-2 transition-all relative cursor-pointer ${\n              subTab === \'rejected\' ? \'text-primary\' : \'text-on-surface-variant hover:text-on-surface\'\n            }`}\n          >\n            Rejected Logs <span className=\"bg-red-500/10 text-red-400 text-[10px] px-2 py-0.5 rounded-full font-mono\">{rejectedSubs.length}</span>\n            {subTab === \'rejected\' && <span className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-primary rounded-full\" />}\n          </button>\n        </div>\n      </div>\n\n      {/* Grid Layout: Moderation stack + Prayer Kanban */}\n      <div className=\"grid grid-cols-12 gap-6 items-start\">\n        \n        {/* Moderation Stack (Col Span 5) */}\n        <section className=\"col-span-12 lg:col-span-5 flex flex-col gap-4 h-[580px]\">\n          <div className=\"flex items-center justify-between mb-1\">\n            <h4 className=\"font-sans text-sm font-bold text-on-surface flex items-center gap-1.5\">\n              <Gavel className=\"w-4 h-4 text-primary\" />\n              Moderation Stack\n            </h4>\n            <span className=\"font-mono text-[9px] text-on-surface-variant uppercase\">SLA: 2.4 HRS</span>\n          </div>\n\n          <div className=\"flex-1 overflow-y-auto space-y-4 pr-1 custom-scrollbar\">\n            {subTab === \'pending\' && (\n              pendingSubs.length > 0 ? (\n                pendingSubs.map((sub) => (\n                  <div key={sub.id} className=\"glass-card p-5 rounded-xl border-l-4 border-l-primary flex flex-col gap-3 group transition-all\">\n                    <div className=\"flex justify-between items-start\">\n                      <div className=\"flex items-center gap-2.5\">\n                        <div className=\"w-8 h-8 rounded-lg bg-surface-container-high border border-outline-variant flex items-center justify-center text-primary text-xs font-bold font-mono\">\n                          {sub.name.substring(0, 2)}\n                        </div>\n                        <div>\n                          <p className=\"font-sans text-xs font-bold text-on-surface leading-tight\">{sub.name}</p>\n                          <span className=\"font-mono text-[9px] text-on-surface-variant\">{sub.timeAgo} \342\200\242 <span className=\"text-primary font-bold\">{sub.type}</span></span>\n                        </div>\n                      </div>\n                      <span className=\"font-mono text-[9px] bg-surface-container-highest px-2 py-0.5 rounded text-on-surface-variant\">ID: #{sub.id.substring(3)}</span>\n                    </div>\n\n                    <div className=\"bg-surface-container-lowest/40 p-3 rounded-lg border border-outline-variant/20 h-28 overflow-y-auto custom-scrollbar\">\n                      <p className=\"font-sans text-xs text-on-surface-variant italic leading-relaxed\">\n                        {sub.content}\n                      </p>\n                    </div>\n\n                    <div className=\"flex gap-2 font-sans mt-1\">\n                      <button \n                        onClick={() => {\n                          onRejectSubmission(sub.id);\n                          alert(\'Submission moved to Rejected Logs.\');\n                        }}\n                        className=\"flex-1 flex items-center justify-center gap-1 bg-on-tertiary-container/30 hover:bg-on-tertiary-container/50 text-error hover:text-white transition-colors py-2 rounded-lg text-xs font-bold cursor-pointer\"\n                      >\n                        <X className=\"w-3.5 h-3.5\" /> Reject\n                      </button>\n                      <button \n                        onClick={() => {\n                          onApproveSubmission(sub.id);\n                          alert(\'Submission approved and published successfully.\');\n                        }}\n                        className=\"flex-1 flex items-center justify-center gap-1 bg-primary/20 hover:bg-primary text-primary hover:text-background transition-colors py-2 rounded-lg text-xs font-bold cursor-pointer\"\n                      >\n                        <Check className=\"w-3.5 h-3.5 animate-bounce\" /> Approve\n                      </button>\n                    </div>\n                  </div>\n                ))\n              ) : (\n                <div className=\"text-center py-16 bg-surface-container-low rounded-xl border border-dashed border-outline-variant text-on-surface-variant text-xs font-sans\">\n                  No submissions pending moderation. Excellent job!\n                </div>\n              )\n            )}\n\n            {subTab === \'published\' && (\n              approvedSubs.length > 0 ? (\n                approvedSubs.map((sub) => (\n                  <div key={sub.id} className=\"glass-card p-4 rounded-xl border-l-4 border-l-emerald-500 opacity-80 flex flex-col gap-2\">\n                    <div className=\"flex justify-between items-start\">\n                      <p className=\"text-xs font-bold text-on-surface\">{sub.name} <span className=\"text-[10px] text-emerald-400 font-mono ml-2\">APPROVED</span></p>\n                      <span className=\"text-[9px] font-mono text-on-surface-variant\">ID: #{sub.id.substring(3)}</span>\n                    </div>\n                    <p className=\"text-xs text-on-surface-variant leading-relaxed line-clamp-3 italic\">\n                      {sub.content}\n                    </p>\n                  </div>\n                ))\n              ) : (\n                <div className=\"text-center py-16 bg-surface-container-low rounded-xl border border-dashed border-outline-variant text-on-surface-variant text-xs font-sans\">\n                  No approved logs yet.\n                </div>\n              )\n            )}\n\n            {subTab === \'rejected\' && (\n              rejectedSubs.length > 0 ? (\n                rejectedSubs.map((sub) => (\n                  <div key={sub.id} className=\"glass-card p-4 rounded-xl border-l-4 border-l-red-500 opacity-60 flex flex-col gap-2\">\n                    <div className=\"flex justify-between items-start\">\n                      <p className=\"text-xs font-bold text-on-surface\">{sub.name} <span className=\"text-[10px] text-red-400 font-mono ml-2\">REJECTED</span></p>\n                      <span className=\"text-[9px] font-mono text-on-surface-variant\">ID: #{sub.id.substring(3)}</span>\n                    </div>\n                    <p className=\"text-xs text-on-surface-variant leading-relaxed line-clamp-3 italic\">\n                      {sub.content}\n                    </p>\n                  </div>\n                ))\n              ) : (\n                <div className=\"text-center py-16 bg-surface-container-low rounded-xl border border-dashed border-outline-variant text-on-surface-variant text-xs font-sans\">\n                  No rejected entries yet.\n                </div>\n              )\n            )}\n          </div>\n        </section>\n\n        {/* Prayer Kanban Board (Col Span 7) */}\n        <section className=\"col-span-12 lg:col-span-7 flex flex-col gap-4 h-[580px]\">\n          <div className=\"flex items-center justify-between mb-1\">\n            <h4 className=\"font-sans text-sm font-bold text-on-surface flex items-center gap-1.5\">\n              <Heart className=\"w-4 h-4 text-primary fill-primary\" />\n              Prayer Kanban Board\n            </h4>\n            <div className=\"flex gap-1\">\n              <button \n                onClick={() => alert(\'Filter prayers option coming soon...\')}\n                className=\"w-7 h-7 rounded bg-surface-container-high flex items-center justify-center text-on-surface-variant hover:text-primary cursor-pointer\"\n                title=\"Filter Prayer Board\"\n              >\n                <Filter className=\"w-3.5 h-3.5\" />\n              </button>\n            </div>\n          </div>\n\n          <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-3 flex-1 h-full overflow-hidden\">\n            {/* Column 1: New Queue */}\n            <div className=\"flex flex-col gap-2 h-full bg-surface-container-lowest/30 rounded-xl p-2 border border-outline-variant/10\">\n              <div className=\"flex items-center gap-2 px-2.5 py-1.5 bg-surface-container-high rounded-lg border-b-2 border-primary font-mono text-[10px] uppercase font-bold tracking-wider text-on-surface\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-primary animate-pulse\"></span>\n                <span>New Queue</span>\n                <span className=\"ml-auto text-on-surface-variant\">{newPrayers.length}</span>\n              </div>\n              <div className=\"flex-1 overflow-y-auto space-y-2 pb-4 custom-scrollbar\">\n                {newPrayers.length > 0 ? (\n                  newPrayers.map((p) => (\n                    <div key={p.id} className=\"glass-card p-3 rounded-lg flex flex-col gap-2.5 hover:border-primary/50 transition-all\">\n                      <span className=\"self-start bg-secondary-container/50 text-secondary text-[8px] font-mono font-bold px-1.5 py-0.5 rounded uppercase tracking-wider\">\n                        {p.category}\n                      </span>\n                      <p className=\"text-xs text-on-surface-variant leading-relaxed line-clamp-3\">{p.text}</p>\n                      <div className=\"flex items-center justify-between mt-1 pt-2 border-t border-outline-variant/10\">\n                        <span className=\"text-[9px] text-on-surface-variant italic font-mono\">- {p.author}</span>\n                        <button \n                          onClick={() => onUpdatePrayerStage(p.id, \'active\')}\n                          className=\"text-primary hover:bg-primary/10 px-2 py-0.5 rounded text-[9px] font-bold flex items-center gap-0.5 cursor-pointer\"\n                          title=\"Move to Active Prayer\"\n                        >\n                          Next <ArrowRight className=\"w-2.5 h-2.5\" />\n                        </button>\n                      </div>\n                    </div>\n                  ))\n                ) : (\n                  <div className=\"text-center py-10 text-on-surface-variant text-[11px] font-sans\">\n                    Queue empty.\n                  </div>\n                )}\n              </div>\n            </div>\n\n            {/* Column 2: Active Prayer */}\n            <div className=\"flex flex-col gap-2 h-full bg-surface-container-lowest/30 rounded-xl p-2 border border-outline-variant/10\">\n              <div className=\"flex items-center gap-2 px-2.5 py-1.5 bg-surface-container-high rounded-lg border-b-2 border-secondary font-mono text-[10px] uppercase font-bold tracking-wider text-on-surface\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-secondary\"></span>\n                <span>Active Prayer</span>\n                <span className=\"ml-auto text-on-surface-variant\">{activePrayers.length}</span>\n              </div>\n              <div className=\"flex-1 overflow-y-auto space-y-2 pb-4 custom-scrollbar\">\n                {activePrayers.length > 0 ? (\n                  activePrayers.map((p) => (\n                    <div key={p.id} className=\"glass-card p-3 rounded-lg flex flex-col gap-2.5 hover:border-secondary/50 transition-all border-l-2 border-l-secondary\">\n                      <span className=\"self-start bg-secondary-container/50 text-secondary text-[8px] font-mono font-bold px-1.5 py-0.5 rounded uppercase tracking-wider\">\n                        {p.category}\n                      </span>\n                      <p className=\"text-xs text-on-surface-variant leading-relaxed line-clamp-3\">{p.text}</p>\n                      <div className=\"flex items-center justify-between mt-1 pt-2 border-t border-outline-variant/10\">\n                        <span className=\"text-[9px] text-on-surface-variant italic font-mono\">{p.prayingCount} leaders praying</span>\n                        <button \n                          onClick={() => onUpdatePrayerStage(p.id, \'archived\')}\n                          className=\"text-secondary hover:bg-secondary/10 px-2 py-0.5 rounded text-[9px] font-bold flex items-center gap-0.5 cursor-pointer\"\n                          title=\"Archive Prayer Request\"\n                        >\n                          Archive <ArrowRight className=\"w-2.5 h-2.5\" />\n                        </button>\n                      </div>\n                    </div>\n                  ))\n                ) : (\n                  <div className=\"text-center py-10 text-on-surface-variant text-[11px] font-sans\">\n                    No active requests.\n                  </div>\n                )}\n              </div>\n            </div>\n\n            {/* Column 3: Archived */}\n            <div className=\"flex flex-col gap-2 h-full bg-surface-container-lowest/30 rounded-xl p-2 border border-outline-variant/10\">\n              <div className=\"flex items-center gap-2 px-2.5 py-1.5 bg-surface-container-high rounded-lg border-b-2 border-on-primary-container font-mono text-[10px] uppercase font-bold tracking-wider text-on-surface\">\n                <CheckCircle className=\"w-3.5 h-3.5 text-primary\" />\n                <span>Archived / Praise</span>\n                <span className=\"ml-auto text-on-surface-variant\">{archivedPrayers.length}</span>\n              </div>\n              <div className=\"flex-1 overflow-y-auto space-y-2 pb-4 custom-scrollbar opacity-75 grayscale hover:grayscale-0 hover:opacity-100 transition-all\">\n                {archivedPrayers.length > 0 ? (\n                  archivedPrayers.map((p) => (\n                    <div key={p.id} className=\"glass-card p-3 rounded-lg flex flex-col gap-2 bg-surface-container-low/30 border-dashed\">\n                      <div className=\"flex justify-between items-start\">\n                        <span className=\"text-[9px] font-mono text-on-surface-variant uppercase\">COMPLETED / PRAISE</span>\n                        <Check className=\"w-3.5 h-3.5 text-primary\" />\n                      </div>\n                      <p className=\"text-xs text-on-surface-variant leading-relaxed line-clamp-3 font-sans italic\">{p.text}</p>\n                      <span className=\"text-[9px] text-on-surface-variant italic font-mono self-end\">- {p.author}</span>\n                    </div>\n                  ))\n                ) : (\n                  <div className=\"text-center py-10 text-on-surface-variant text-[11px] font-sans\">\n                    No items archived yet.\n                  </div>\n                )}\n              </div>\n            </div>\n          </div>\n        </section>\n      </div>\n\n      {/* System Stats Footer Row */}\n      <footer className=\"grid grid-cols-2 md:grid-cols-4 gap-4 opacity-70 hover:opacity-100 transition-opacity\">\n        <div className=\"glass-card p-4 rounded-xl flex items-center gap-3\">\n          <div className=\"bg-primary/10 p-2 rounded-lg text-primary\">\n            <Cpu className=\"w-4 h-4 text-primary animate-pulse\" />\n          </div>\n          <div>\n            <p className=\"text-[10px] font-mono text-on-surface-variant\">REAL-TIME LATENCY</p>\n            <p className=\"font-sans font-bold text-on-surface text-sm\">14ms</p>\n          </div>\n        </div>\n\n        <div className=\"glass-card p-4 rounded-xl flex items-center gap-3\">\n          <div className=\"bg-secondary/10 p-2 rounded-lg text-secondary\">\n            <Database className=\"w-4 h-4 text-secondary\" />\n          </div>\n          <div>\n            <p className=\"text-[10px] font-mono text-on-surface-variant\">ACTIVE DATA NODES</p>\n            <p className=\"font-sans font-bold text-on-surface text-sm\">8/12</p>\n          </div>\n        </div>\n\n        <div className=\"col-span-2 glass-card p-4 rounded-xl flex items-center justify-between\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"bg-tertiary-container/10 p-2 rounded-lg text-tertiary-container\">\n              <Lock className=\"w-4 h-4 text-tertiary-container\" />\n            </div>\n            <div>\n              <p className=\"text-[10px] font-mono text-on-surface-variant\">SYSTEM STATUS</p>\n              <p className=\"font-sans font-bold text-on-surface text-sm\">Shield Protocol Active</p>\n            </div>\n          </div>\n          <div className=\"hidden sm:flex gap-1 h-1.5\">\n            <div className=\"w-6 bg-primary rounded-full\"></div>\n            <div className=\"w-3 bg-primary/40 rounded-full\"></div>\n            <div className=\"w-10 bg-primary rounded-full\"></div>\n          </div>\n        </div>\n      </footer>\n\n      {/* Add Prayer Request Form Modal */}\n      {showAddPrayer && (\n        <div className=\"fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50 p-4\">\n          <div className=\"bg-surface-container border border-outline-variant w-full max-w-sm rounded-2xl overflow-hidden shadow-2xl font-sans\">\n            <div className=\"p-6 border-b border-outline-variant flex justify-between items-center bg-surface-container-high\">\n              <h3 className=\"font-sans text-md font-bold text-on-surface\">Submit Prayer Request</h3>\n              <button \n                onClick={() => setShowAddPrayer(false)}\n                className=\"p-1 rounded-lg hover:bg-surface-container-low text-on-surface-variant hover:text-on-surface transition-all\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n            </div>\n            \n            <form onSubmit={handleAddPrayer} className=\"p-6 space-y-4 text-sm\">\n              <div>\n                <label className=\"block text-xs font-semibold text-on-surface-variant uppercase mb-1\">Category / Tag</label>\n                <select \n                  value={newPrayerCategory}\n                  onChange={(e) => setNewPrayerCategory(e.target.value)}\n                  className=\"w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary\"\n                >\n                  <option value=\"STUDIES\">STUDIES</option>\n                  <option value=\"FAMILY\">FAMILY</option>\n                  <option value=\"FRIENDSHIP\">FRIENDSHIP</option>\n                  <option value=\"HEALTH\">HEALTH</option>\n                  <option value=\"SPIRITUAL\">SPIRITUAL</option>\n                </select>\n              </div>\n\n              <div>\n                <label className=\"block text-xs font-semibold text-on-surface-variant uppercase mb-1\">Author Name (Optional)</label>\n                <input \n                  type=\"text\" \n                  value={newPrayerAuthor}\n                  onChange={(e) => setNewPrayerAuthor(e.target.value)}\n                  placeholder=\"e.g. Elena R. or Anonymous\"\n                  className=\"w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary transition-all\"\n                />\n              </div>\n\n              <div>\n                <label className=\"block text-xs font-semibold text-on-surface-variant uppercase mb-1\">Prayer Details</label>\n                <textarea \n                  value={newPrayerText}\n                  onChange={(e) => setNewPrayerText(e.target.value)}\n                  placeholder=\"Write what you would like the team to pray for...\"\n                  rows={4}\n                  className=\"w-full bg-background border border-outline-variant rounded-lg px-3 py-2 text-sm text-on-surface focus:outline-none focus:border-primary transition-all resize-none leading-relaxed\"\n                />\n              </div>\n\n              <div className=\"pt-2 flex justify-end gap-3\">\n                <button \n                  type=\"button\"\n                  onClick={() => setShowAddPrayer(false)}\n                  className=\"px-4 py-2 bg-surface-container-high hover:bg-surface-container border border-outline-variant text-on-surface text-xs font-semibold rounded-lg transition-all\"\n                >\n                  Cancel\n                </button>\n                <button \n                  type=\"submit\"\n                  className=\"px-5 py-2 bg-primary text-background font-bold text-xs rounded-lg hover:opacity-90 transition-all flex items-center gap-1\"\n                >\n                  <Check className=\"w-4 h-4\" /> Register\n                </button>\n              </div>\n            </form>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n"
