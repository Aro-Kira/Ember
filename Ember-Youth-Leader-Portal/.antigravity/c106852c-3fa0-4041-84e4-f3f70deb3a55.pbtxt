    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport { \n  Menu, \n  Bell, \n  Calendar, \n  ChevronRight, \n  Clock, \n  AlertCircle,\n  CheckCircle,\n  LogOut,\n  Sparkles,\n  FlameKindling\n} from \'lucide-react\';\n\nimport { NavTab, YouthMember, Announcement, PortalEvent, ModerationSubmission, PrayerItem } from \'./types\';\nimport { \n  INITIAL_MEMBERS, \n  INITIAL_ANNOUNCEMENTS, \n  INITIAL_EVENTS, \n  INITIAL_SUBMISSIONS, \n  INITIAL_PRAYER_ITEMS \n} from \'./data\';\n\nimport Sidebar from \'./components/Sidebar\';\nimport DashboardOverview from \'./components/DashboardOverview\';\nimport MembersDirectory from \'./components/MembersDirectory\';\nimport AnnouncementsHub from \'./components/AnnouncementsHub\';\nimport EventsManager from \'./components/EventsManager\';\nimport ModerationHub from \'./components/ModerationHub\';\nimport AttendanceScannerView from \'./components/AttendanceScannerView\';\n\nexport default function App() {\n  // Navigation & Drawer state\n  const [activeTab, setActiveTab] = useState<NavTab>(\'overview\');\n  const [sidebarOpen, setSidebarOpen] = useState(false);\n\n  // Global Reactive States\n  const [members, setMembers] = useState<YouthMember[]>(INITIAL_MEMBERS);\n  const [announcements, setAnnouncements] = useState<Announcement[]>(INITIAL_ANNOUNCEMENTS);\n  const [events, setEvents] = useState<PortalEvent[]>(INITIAL_EVENTS);\n  const [submissions, setSubmissions] = useState<ModerationSubmission[]>(INITIAL_SUBMISSIONS);\n  const [prayerItems, setPrayerItems] = useState<PrayerItem[]>(INITIAL_PRAYER_ITEMS);\n\n  // Live Clock State\n  const [currentTime, setCurrentTime] = useState(\'\');\n\n  useEffect(() => {\n    const updateTime = () => {\n      const now = new Date();\n      setCurrentTime(now.toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\', second: \'2-digit\' }));\n    };\n    updateTime();\n    const interval = setInterval(updateTime, 1000);\n    return () => clearInterval(interval);\n  }, []);\n\n  // Handler: Add Member\n  const handleAddMember = (newMember: Omit<YouthMember, \'id\' | \'emberId\' | \'joinedDate\'>) => {\n    const randomId = Math.floor(1000 + Math.random() * 9000).toString();\n    const formattedDate = new Date().toLocaleDateString(\'en-US\', {\n      month: \'short\',\n      day: \'2-digit\',\n      year: \'numeric\'\n    });\n\n    const created: YouthMember = {\n      ...newMember,\n      id: `m-${randomId}`,\n      emberId: `#EMB-${randomId}`,\n      joinedDate: formattedDate\n    };\n\n    setMembers(prev => [created, ...prev]);\n  };\n\n  // Handler: Update Member\n  const handleUpdateMember = (updated: YouthMember) => {\n    setMembers(prev => prev.map(m => m.id === updated.id ? updated : m));\n  };\n\n  // Handler: Add Announcement\n  const handleAddAnnouncement = (newAnn: Omit<Announcement, \'id\' | \'views\' | \'date\' | \'authorName\' | \'authorAvatar\'>) => {\n    const created: Announcement = {\n      ...newAnn,\n      id: `a-${Date.now()}`,\n      views: 0,\n      date: \'Just now\',\n      authorName: \'Alex Rivera\',\n      authorAvatar: \'https://lh3.googleusercontent.com/aida-public/AB6AXuC3j0iMcJukmdOVIrdKqXct652DjZaGVopriJUcla9B6FKUMl-c7pojuMZdzhHbQeCds9QlyAnmg3aH4TXnCId3p5DwrCDujO5esmccI2Kqcj4rjpY-w5SNSwhTVloIxcaPb4lOqAyGNPQXjFHhErgVj_wZ-IXSoZpmjyXTeJnFKteoL88V-dGftNBFBHlvs7C5So0e4fm00o0TpnQlqJdV-Te-x6Cnkv2ceVdsOCSg5WckdFdzTUPTTv9Z1ChyCB1wTbK3gPBTs-zm\'\n    };\n\n    setAnnouncements(prev => [created, ...prev]);\n  };\n\n  // Handler: Add Event\n  const handleAddEvent = (newEvent: Omit<PortalEvent, \'id\' | \'checkedIn\'>) => {\n    const created: PortalEvent = {\n      ...newEvent,\n      id: `e-${Date.now()}`,\n      checkedIn: 0\n    };\n\n    setEvents(prev => [created, ...prev]);\n  };\n\n  // Handler: Update Event\n  const handleUpdateEvent = (updated: PortalEvent) => {\n    setEvents(prev => prev.map(ev => ev.id === updated.id ? updated : ev));\n  };\n\n  // Handler: Approve Moderation Submission\n  const handleApproveSubmission = (id: string) => {\n    setSubmissions(prev => prev.map(sub => sub.id === id ? { ...sub, status: \'approved\' } : sub));\n    \n    // Automatically publish testimonies into Announcements feed if desired\n    const target = submissions.find(s => s.id === id);\n    if (target) {\n      handleAddAnnouncement({\n        title: `Youth Testimony: Share from ${target.name}`,\n        content: target.content,\n        priority: \'Normal\',\n        targetAudience: \'All Youth\',\n        status: \'Active\',\n        coverImage: \'https://images.unsplash.com/photo-1501386761578-eac5c94b800a?auto=format&fit=crop&q=80&w=400\'\n      });\n    }\n  };\n\n  // Handler: Reject Moderation Submission\n  const handleRejectSubmission = (id: string) => {\n    setSubmissions(prev => prev.map(sub => sub.id === id ? { ...sub, status: \'rejected\' } : sub));\n  };\n\n  // Handler: Update Prayer stage\n  const handleUpdatePrayerStage = (id: string, stage: \'new\' | \'active\' | \'archived\') => {\n    setPrayerItems(prev => prev.map(p => {\n      if (p.id === id) {\n        return {\n          ...p,\n          stage,\n          prayingCount: stage === \'active\' ? p.prayingCount + 1 : p.prayingCount\n        };\n      }\n      return p;\n    }));\n  };\n\n  // Handler: Add Prayer Item\n  const handleAddPrayerItem = (item: Omit<PrayerItem, \'id\' | \'prayingCount\'>) => {\n    const created: PrayerItem = {\n      ...item,\n      id: `pr-${Date.now()}`,\n      prayingCount: 1\n    };\n\n    setPrayerItems(prev => [created, ...prev]);\n  };\n\n  // Handler: Live QR Scanner check-in bridge\n  const handleCheckInMember = (emberId: string) => {\n    // 1. Find corresponding student member\n    const student = members.find(m => m.emberId === emberId);\n    if (student) {\n      // Toggle student\'s status to Active if inactive\n      if (student.status === \'Inactive\') {\n        handleUpdateMember({ ...student, status: \'Active\' });\n      }\n\n      // 2. Increment check-in attendance on today\'s active live event (e.g., Youth Night Live)\n      const liveEvent = events.find(e => e.type === \'live\');\n      if (liveEvent) {\n        const nextCheckedIn = Math.min(liveEvent.checkedIn + 1, liveEvent.registered);\n        handleUpdateEvent({\n          ...liveEvent,\n          checkedIn: nextCheckedIn\n        });\n      }\n    }\n  };\n\n  // Breadcrumbs title helper\n  const getTabTitle = () => {\n    switch (activeTab) {\n      case \'overview\': return \'Overview Dashboard\';\n      case \'members\': return \'Youth Members Directory\';\n      case \'announcements\': return \'Announcements Hub\';\n      case \'events\': return \'Events & Calendar Manager\';\n      case \'moderation\': return \'Queue & Prayer Board\';\n      case \'scanner\': return \'Live QR Check-In\';\n      default: return \'Youth Leader Portal\';\n    }\n  };\n\n  // Pending items counts for warning banner\n  const pendingSubmissionsCount = submissions.filter(s => s.status === \'pending\').length;\n\n  return (\n    <div className=\"min-h-screen bg-surface-dim flex\">\n      {/* Sidebar Navigation */}\n      <Sidebar \n        activeTab={activeTab} \n        setActiveTab={setActiveTab} \n        isOpen={sidebarOpen} \n        onClose={() => setSidebarOpen(false)}\n        onLaunchScanner={() => setActiveTab(\'scanner\')}\n      />\n\n      {/* Main Container Content */}\n      <div className=\"flex-1 lg:pl-64 flex flex-col min-h-screen overflow-hidden\">\n        \n        {/* Responsive Portal Header */}\n        <header className=\"sticky top-0 z-30 bg-surface-container-low/80 backdrop-blur-md border-b border-outline-variant px-6 py-4 flex items-center justify-between\">\n          <div className=\"flex items-center gap-3\">\n            {/* Hamburger Button for Mobile */}\n            <button \n              onClick={() => setSidebarOpen(true)}\n              className=\"lg:hidden p-2 rounded-lg hover:bg-surface-container-high text-on-surface-variant hover:text-on-surface transition-colors cursor-pointer\"\n            >\n              <Menu className=\"w-5 h-5\" />\n            </button>\n            \n            {/* Breadcrumb Title */}\n            <div>\n              <div className=\"hidden sm:flex items-center gap-1.5 font-mono text-[10px] text-on-surface-variant uppercase tracking-widest\">\n                <span>EMBER PORTAL</span>\n                <ChevronRight className=\"w-3 h-3 text-outline\" />\n                <span className=\"text-primary font-bold\">{activeTab}</span>\n              </div>\n              <h2 className=\"font-sans text-md sm:text-lg font-black text-on-surface leading-none mt-0.5\">\n                {getTabTitle()}\n              </h2>\n            </div>\n          </div>\n\n          {/* Quick Header Widgets */}\n          <div className=\"flex items-center gap-4\">\n            {/* Real-time Clock widget */}\n            <div className=\"hidden md:flex items-center gap-2 bg-surface-container-high border border-outline-variant/60 rounded-xl px-3.5 py-1.5 font-mono text-xs text-on-surface\">\n              <Clock className=\"w-3.5 h-3.5 text-primary\" />\n              <span>{currentTime || \'12:00:00 PM\'}</span>\n              <span className=\"text-on-surface-variant opacity-60\">UTC</span>\n            </div>\n\n            {/* Moderation Pending Notification Badge */}\n            {pendingSubmissionsCount > 0 && (\n              <button \n                onClick={() => setActiveTab(\'moderation\')}\n                className=\"relative p-2 rounded-xl bg-surface-container-high hover:bg-surface-container border border-outline-variant/60 text-primary hover:text-on-surface transition-all cursor-pointer flex items-center gap-1\"\n                title={`${pendingSubmissionsCount} submissions pending moderation`}\n              >\n                <Bell className=\"w-4 h-4 text-primary animate-pulse\" />\n                <span className=\"font-mono text-[10px] font-bold bg-primary text-background px-1.5 py-0.2 rounded-full leading-none\">\n                  {pendingSubmissionsCount}\n                </span>\n              </button>\n            )}\n\n            {/* Main Profile Info Header */}\n            <div className=\"flex items-center gap-3 pl-2 border-l border-outline-variant/40\">\n              <img \n                className=\"w-8 h-8 rounded-full border border-primary/25 object-cover\" \n                src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuC3j0iMcJukmdOVIrdKqXct652DjZaGVopriJUcla9B6FKUMl-c7pojuMZdzhHbQeCds9QlyAnmg3aH4TXnCId3p5DwrCDujO5esmccI2Kqcj4rjpY-w5SNSwhTVloIxcaPb4lOqAyGNPQXjFHhErgVj_wZ-IXSoZpmjyXTeJnFKteoL88V-dGftNBFBHlvs7C5So0e4fm00o0TpnQlqJdV-Te-x6Cnkv2ceVdsOCSg5WckdFdzTUPTTv9Z1ChyCB1wTbK3gPBTs-zm\" \n                alt=\"Pastor Alex\" \n                referrerPolicy=\"no-referrer\"\n              />\n              <div className=\"hidden sm:block\">\n                <p className=\"font-sans text-xs font-bold text-on-surface\">Alex Rivera</p>\n                <p className=\"font-mono text-[9px] text-on-surface-variant leading-none uppercase\">Portal Master</p>\n              </div>\n            </div>\n          </div>\n        </header>\n\n        {/* Workspace Feed Area */}\n        <main className=\"flex-1 p-6 overflow-y-auto max-w-[1500px] w-full mx-auto\">\n          {activeTab === \'overview\' && (\n            <DashboardOverview \n              members={members} \n              events={events}\n              prayerCount={prayerItems.filter(p => p.stage !== \'archived\').length}\n              onNavigate={setActiveTab}\n            />\n          )}\n\n          {activeTab === \'members\' && (\n            <MembersDirectory \n              members={members} \n              onAddMember={handleAddMember}\n              onUpdateMember={handleUpdateMember}\n            />\n          )}\n\n          {activeTab === \'announcements\' && (\n            <AnnouncementsHub \n              announcements={announcements} \n              onAddAnnouncement={handleAddAnnouncement}\n            />\n          )}\n\n          {activeTab === \'events\' && (\n            <EventsManager \n              events={events} \n              onAddEvent={handleAddEvent}\n              onUpdateEvent={handleUpdateEvent}\n            />\n          )}\n\n          {activeTab === \'moderation\' && (\n            <ModerationHub \n              submissions={submissions}\n              prayerItems={prayerItems}\n              onApproveSubmission={handleApproveSubmission}\n              onRejectSubmission={handleRejectSubmission}\n              onUpdatePrayerStage={handleUpdatePrayerStage}\n              onAddPrayerItem={handleAddPrayerItem}\n            />\n          )}\n\n          {activeTab === \'scanner\' && (\n            <AttendanceScannerView \n              onCheckInMember={handleCheckInMember}\n              members={members}\n            />\n          )}\n        </main>\n      </div>\n    </div>\n  );\n}\n"
    }
