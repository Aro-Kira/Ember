      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport {\n  Flame,\n  Bell,\n  BookOpen,\n  MessageSquare,\n  Heart,\n  Calendar,\n  QrCode,\n  User,\n  Plus,\n  Search,\n  Award,\n  Zap,\n  Sparkles,\n  ChevronRight,\n  ChevronLeft,\n  LogOut,\n  Settings,\n  Send,\n  CheckCircle2,\n  MapPin,\n  Clock,\n  AlertTriangle,\n  UserCheck,\n  Smile,\n  Share2,\n  X,\n  Lock,\n  ThumbsUp,\n  FileText,\n  UserPlus\n} from \'lucide-react\';\n\n// Types for application state\ninterface UserProfile {\n  name: string;\n  avatar: string;\n  id: string;\n  level: number;\n  streak: number;\n  points: number;\n  checkIns: number;\n  checkInsTarget: number;\n  prayersShared: number;\n  postsCount: number;\n  bio?: string;\n}\n\ninterface SubmittedPost {\n  id: string;\n  title: string;\n  body: string;\n  type: \'devotional\' | \'testimony\';\n  timestamp: string;\n  status: \'Pending Review\' | \'Approved\';\n}\n\ninterface EventItem {\n  id: string;\n  title: string;\n  date: string;\n  time: string;\n  location: string;\n  image: string;\n  description: string;\n  pointsReward: number;\n  price: string;\n  registered: boolean;\n}\n\ninterface PrayerRequest {\n  id: string;\n  author: string;\n  avatar: string;\n  content: string;\n  prayersCount: number;\n  hasPrayed: boolean;\n  timeAgo: string;\n}\n\nexport default function App() {\n  // Navigation State\n  const [activeTab, setActiveTab] = useState<\'home\' | \'events\' | \'check-in\' | \'posts\' | \'prayers\' | \'profile\'>(\'home\');\n  const [isLoggedIn, setIsLoggedIn] = useState<boolean>(true);\n  \n  // Modals & Flows State\n  const [showNotificationDrawer, setShowNotificationDrawer] = useState(false);\n  const [showEventRegisterModal, setShowEventRegisterModal] = useState<EventItem | null>(null);\n  const [showEditProfileModal, setShowEditProfileModal] = useState(false);\n  const [showMyContributionsModal, setShowMyContributionsModal] = useState(false);\n  const [checkInScanning, setCheckInScanning] = useState(false);\n  const [checkInSuccess, setCheckInSuccess] = useState(false);\n  const [justCheckedInToday, setJustCheckedInToday] = useState(false);\n\n  // User Profile State (Persisted in localStorage)\n  const [profile, setProfile] = useState<UserProfile>(() => {\n    const saved = localStorage.getItem(\'ember_user_profile\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {\n        // Fallback below\n      }\n    }\n    return {\n      name: \'Aaron\',\n      avatar: \'https://lh3.googleusercontent.com/aida-public/AB6AXuANk-XFd6Gvyzx3kDej5Vtr4qf7gdca2Ll7BpF8VLWScwITBIt3mSVHjs-z4xPHJL6EwAJ2ckm3Q-55XC8gWGPEx57m6KQpWck8meaFuCAtrFlzw_qTelRK0rj-HAWERrVlfR_OykTH8PPRnRb9-6eSW9iFkMAteloRfIV96cHcUv2pmg-UW3x20ZEgD8HEUqXFmiwC35zv5CjfyhHhaEjlo9TXvY11W1V9E50-BD6lM-byECVW1G-AP8iz5AFl2uJ4oqUCe45EEp3d\',\n      id: \'EMB-0429-X\',\n      level: 12,\n      streak: 4,\n      points: 450,\n      checkIns: 12,\n      checkInsTarget: 15,\n      prayersShared: 8,\n      postsCount: 3,\n      bio: \'Ember Youth Leader Explorer \342\200\242 Passionate about media design & community building.\'\n    };\n  });\n\n  // Submitted Posts State (Devotionals / Testimonies)\n  const [submittedPosts, setSubmittedPosts] = useState<SubmittedPost[]>(() => {\n    const saved = localStorage.getItem(\'ember_submitted_posts\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {}\n    }\n    return [\n      {\n        id: \'post-1\',\n        title: \'Finding Peace in Chaos\',\n        body: \'In the midst of high school exams and extracurricular schedules, I realized that taking just 10 minutes every morning to read Psalm 46:10 changed my entire outlook. Be still, and know that I am God.\',\n        type: \'devotional\',\n        timestamp: \'2 days ago\',\n        status: \'Approved\'\n      },\n      {\n        id: \'post-2\',\n        title: \'My Journey at Winter Camp\',\n        body: \'I went into the youth winter camp feeling disconnected and unsure of my calling. During the Saturday worship session, the speaker talked about living with a heart on fire. That night, I rededicated my walk with God and found a family here.\',\n        type: \'testimony\',\n        timestamp: \'1 week ago\',\n        status: \'Approved\'\n      }\n    ];\n  });\n\n  // Events list with interactive RSVP states\n  const [events, setEvents] = useState<EventItem[]>(() => {\n    const saved = localStorage.getItem(\'ember_events_list\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {}\n    }\n    return [\n      {\n        id: \'event-1\',\n        title: \'Ignite Youth Camp 2026\',\n        date: \'JULY 15-18\',\n        time: \'9:00 AM - 5:00 PM\',\n        location: \'Mountain Valley Retreat Center\',\n        image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuAIa25iDUQr9Gp9A9N50B0k7vwh4la2xmzFeEqRledK3pQxHTWuv87yAy_SRD_maAIKVgkEfRZ7NPX-VL1Fa2QCkfR7JxMlw2wW9wGA9MdCVhn6LbtGPB9slMWNi8AfuKU05LvYGWkDqBnNVEJwzH7J5sL5yjdC1tgLNQcIniw4JSI_TP7UbOMPHuDnqauscgbbS0p9XwbGq0pXkAQITF7aQEQzfQZ4U60d8kGMSUmAz8LOPfDVfEYExUpkdA8Sb-6CX0G6IyoY9BET\',\n        description: \'Join us for 4 days of powerful worship, deep connections, and life-changing encounters. Early bird registrations are open! Dynamic speakers, team recreation, and lakeside fire talks included.\',\n        pointsReward: 100,\n        price: \'$120 (Scholarships available)\',\n        registered: false\n      },\n      {\n        id: \'event-2\',\n        title: \'Friday Fellowship Night\',\n        date: \'THIS FRIDAY\',\n        time: \'6:00 PM - 9:30 PM\',\n        location: \'Main Sanctuary & Youth Hall\',\n        image: \'https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3\',\n        description: \'Bring a friend for high-energy group games, free pizza, and an inspiring discussion about stepping out of our comfort zones. Doors open at 5:30 PM.\',\n        pointsReward: 30,\n        price: \'FREE\',\n        registered: false\n      },\n      {\n        id: \'event-3\',\n        title: \'Praise & Acoustic Night\',\n        date: \'AUGUST 07\',\n        time: \'7:00 PM - 9:30 PM\',\n        location: \'The Fireplace Lounge\',\n        image: \'https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3\',\n        description: \'An intimate candlelit evening of acoustic worship and personal testimonies. A place to rest, pray, and recharge in His presence.\',\n        pointsReward: 40,\n        price: \'FREE\',\n        registered: false\n      },\n      {\n        id: \'event-4\',\n        title: \'Youth Leadership Summit\',\n        date: \'SEPTEMBER 12\',\n        time: \'10:00 AM - 4:00 PM\',\n        location: \'Multipurpose Auditorium\',\n        image: \'https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800&auto=format&fit=crop&q=60&ixlib=rb-4.0.3\',\n        description: \'Equipping the next generation of small group leaders, AV tech wizards, and worship musicians. Workshops led by veteran youth pastors.\',\n        pointsReward: 75,\n        price: \'$15 (Includes lunch)\',\n        registered: false\n      }\n    ];\n  });\n\n  // Prayer Wall State\n  const [prayers, setPrayers] = useState<PrayerRequest[]>(() => {\n    const saved = localStorage.getItem(\'ember_prayers_list\');\n    if (saved) {\n      try {\n        return JSON.parse(saved);\n      } catch (e) {}\n    }\n    return [\n      {\n        id: \'p-1\',\n        author: \'Chloe Simmons\',\n        avatar: \'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=150&auto=format&fit=crop&q=80\',\n        content: \'Please pray for my grandmother who is undergoing heart surgery tomorrow morning. Asking for steady hands for the surgeons and peace for our family.\',\n        prayersCount: 24,\n        hasPrayed: false,\n        timeAgo: \'4h ago\'\n      },\n      {\n        id: \'p-2\',\n        author: \'Nathan Chen\',\n        avatar: \'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150&auto=format&fit=crop&q=80\',\n        content: \'Dealing with heavy anxiety about college applications and decisions. Praying for trust that His plan is bigger than any acceptance letter.\',\n        prayersCount: 38,\n        hasPrayed: true,\n        timeAgo: \'1d ago\'\n      },\n      {\n        id: \'p-3\',\n        author: \'Sarah Jenkins\',\n        avatar: \'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=150&auto=format&fit=crop&q=80\',\n        content: \'Praising God for healing my little brother from a severe fever! Thank you all who prayed for him last week. Prayer is powerful!\',\n        prayersCount: 42,\n        hasPrayed: false,\n        timeAgo: \'2d ago\'\n      }\n    ];\n  });\n\n  // Submission Inputs\n  const [postType, setPostType] = useState<\'devotional\' | \'testimony\'>(\'devotional\');\n  const [postTitle, setPostTitle] = useState(\'\');\n  const [postBody, setPostBody] = useState(\'\');\n  const [submittingPost, setSubmittingPost] = useState(false);\n  const [postSuccess, setPostSuccess] = useState(false);\n\n  // Prayer Request Inputs\n  const [showNewPrayerModal, setShowNewPrayerModal] = useState(false);\n  const [newPrayerContent, setNewPrayerContent] = useState(\'\');\n\n  // Toast / Status Feedbacks\n  const [toastMessage, setToastMessage] = useState<string | null>(null);\n\n  // Persist state in LocalStorage whenever changes happen\n  useEffect(() => {\n    localStorage.setItem(\'ember_user_profile\', JSON.stringify(profile));\n  }, [profile]);\n\n  useEffect(() => {\n    localStorage.setItem(\'ember_submitted_posts\', JSON.stringify(submittedPosts));\n  }, [submittedPosts]);\n\n  useEffect(() => {\n    localStorage.setItem(\'ember_events_list\', JSON.stringify(events));\n  }, [events]);\n\n  useEffect(() => {\n    localStorage.setItem(\'ember_prayers_list\', JSON.stringify(prayers));\n  }, [prayers]);\n\n  // Utility to trigger toasts\n  const triggerToast = (msg: string) => {\n    setToastMessage(msg);\n    setTimeout(() => {\n      setToastMessage(null);\n    }, 4000);\n  };\n\n  // Quick Action Switchers\n  const handleQuickAction = (action: \'devotional\' | \'testimony\' | \'prayer\') => {\n    if (action === \'devotional\' || action === \'testimony\') {\n      setPostType(action);\n      setActiveTab(\'posts\');\n    } else if (action === \'prayer\') {\n      setActiveTab(\'prayers\');\n      setShowNewPrayerModal(true);\n    }\n  };\n\n  // Submit Post handler\n  const handlePostSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!postTitle.trim() || !postBody.trim()) {\n      triggerToast(\'Please fill in both a title and message body!\');\n      return;\n    }\n\n    setSubmittingPost(true);\n\n    setTimeout(() => {\n      const newPost: SubmittedPost = {\n        id: `post-${Date.now()}`,\n        title: postTitle,\n        body: postBody,\n        type: postType,\n        timestamp: \'Just now\',\n        status: \'Pending Review\'\n      };\n\n      setSubmittedPosts([newPost, ...submittedPosts]);\n      \n      // Update points and post count for submitting!\n      setProfile(prev => ({\n        ...prev,\n        points: prev.points + 25, // +25 points for contribution submission\n        postsCount: prev.postsCount + 1\n      }));\n\n      setSubmittingPost(false);\n      setPostSuccess(true);\n      triggerToast(\'Devotion submitted! Pending leader review. Earned +25 points! \360\237\224\245\');\n\n      setTimeout(() => {\n        setPostSuccess(false);\n        setPostTitle(\'\');\n        setPostBody(\'\');\n      }, 3000);\n    }, 1500);\n  };\n\n  // Submit Prayer Request handler\n  const handlePrayerSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!newPrayerContent.trim()) {\n      triggerToast(\'Please describe your prayer request.\');\n      return;\n    }\n\n    const newPrayer: PrayerRequest = {\n      id: `p-${Date.now()}`,\n      author: profile.name,\n      avatar: profile.avatar,\n      content: newPrayerContent,\n      prayersCount: 0,\n      hasPrayed: false,\n      timeAgo: \'Just now\'\n    };\n\n    setPrayers([newPrayer, ...prayers]);\n    setProfile(prev => ({\n      ...prev,\n      prayersShared: prev.prayersShared + 1,\n      points: prev.points + 15 // +15 points for request\n    }));\n\n    setNewPrayerContent(\'\');\n    setShowNewPrayerModal(false);\n    triggerToast(\'Your prayer request is posted on the Ember Wall! Earned +15 points! \360\237\231\217\');\n  };\n\n  // Support/pray for another person\'s request\n  const handlePrayForPerson = (id: string) => {\n    setPrayers(\n      prayers.map(p => {\n        if (p.id === id) {\n          const updatedPrayed = !p.hasPrayed;\n          // Award points for praying for others!\n          if (updatedPrayed) {\n            setProfile(prev => ({ ...prev, points: prev.points + 5 }));\n            triggerToast(\'You prayed for this request! Earned +5 points! \342\234\250\');\n          }\n          return {\n            ...p,\n            hasPrayed: updatedPrayed,\n            prayersCount: p.prayersCount + (updatedPrayed ? 1 : -1)\n          };\n        }\n        return p;\n      })\n    );\n  };\n\n  // Event Registration form handler\n  const handleRegisterEvent = (eventId: string, details: any) => {\n    setEvents(\n      events.map(ev => {\n        if (ev.id === eventId) {\n          if (!ev.registered) {\n            setProfile(prev => ({\n              ...prev,\n              points: prev.points + ev.pointsReward\n            }));\n            triggerToast(`Registered for ${ev.title}! Earned +${ev.pointsReward} points! \360\237\216\237\357\270\217`);\n          }\n          return { ...ev, registered: true };\n        }\n        return ev;\n      })\n    );\n    setShowEventRegisterModal(null);\n  };\n\n  // Simulating check-in QR scan\n  const handleCheckInScan = () => {\n    if (justCheckedInToday) {\n      triggerToast(\'You have already registered attendance for today\\\'s session!\');\n      return;\n    }\n\n    setCheckInScanning(true);\n\n    setTimeout(() => {\n      setCheckInScanning(false);\n      setCheckInSuccess(true);\n      \n      const newCheckins = profile.checkIns >= profile.checkInsTarget ? 1 : profile.checkIns + 1;\n      const didLevelUp = newCheckins === 1; // Resets cycle or increments level on target? \n      const pointsReward = 30;\n\n      setProfile(prev => ({\n        ...prev,\n        checkIns: newCheckins,\n        points: prev.points + pointsReward + (didLevelUp ? 150 : 0),\n        streak: prev.streak + 1,\n        level: prev.checkIns === prev.checkInsTarget - 1 ? prev.level + 1 : prev.level\n      }));\n\n      setJustCheckedInToday(true);\n      triggerToast(`Attendance check-in verified! Streak is up to ${profile.streak + 1}! Earned +30 points! \360\237\216\222`);\n\n      setTimeout(() => {\n        setCheckInSuccess(false);\n      }, 4000);\n    }, 1500);\n  };\n\n  // Sign In Flow for simulation\n  const [loginInputName, setLoginInputName] = useState(\'Aaron\');\n  const handleLoginSubmit = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!loginInputName.trim()) return;\n\n    setProfile(prev => ({\n      ...prev,\n      name: loginInputName\n    }));\n    setIsLoggedIn(true);\n    triggerToast(`Welcome back, ${loginInputName}! Connecting to EMBER services... \360\237\224\245`);\n  };\n\n  const handleLogout = () => {\n    setIsLoggedIn(false);\n    triggerToast(\'Logged out of Ember successfully.\');\n  };\n\n  if (!isLoggedIn) {\n    return (\n      <div className=\"min-h-screen bg-[#0b1326] text-[#dae2fd] flex flex-col justify-center items-center px-6 py-12 font-hanken\">\n        <div className=\"w-full max-w-md bg-[#171f33] border border-[#2d3449] rounded-2xl p-8 ember-glow-strong text-center\">\n          <div className=\"flex justify-center mb-6\">\n            <div className=\"w-16 h-16 rounded-full bg-[#f59e0b]/10 border border-[#f59e0b]/30 flex items-center justify-center\">\n              <Flame className=\"text-[#ffc174] w-10 h-10 animate-pulse\" />\n            </div>\n          </div>\n          \n          <h1 className=\"font-extrabold text-3xl tracking-tight text-[#ffc174] mb-2 font-hanken\">EMBER</h1>\n          <p className=\"text-sm text-[#d8c3ad] uppercase tracking-widest font-mono mb-8\">Youth Portal Portal Gate</p>\n\n          <form onSubmit={handleLoginSubmit} className=\"space-y-6 text-left\">\n            <div>\n              <label className=\"block text-xs uppercase tracking-widest text-[#d8c3ad] font-mono mb-2\" htmlFor=\"login-name\">\n                Enter Your Member Name\n              </label>\n              <input\n                id=\"login-name\"\n                type=\"text\"\n                value={loginInputName}\n                onChange={(e) => setLoginInputName(e.target.value)}\n                className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-lg py-3 px-4 text-[#dae2fd] placeholder-[#aeb9d0]/40 focus:outline-none focus:ring-1 focus:ring-[#ffc174] focus:border-[#ffc174] transition-all\"\n                placeholder=\"e.g. Aaron\"\n                required\n              />\n            </div>\n\n            <div className=\"p-4 bg-[#060e20] rounded-xl border border-[#2d3449] text-xs text-[#d8c3ad] leading-relaxed flex gap-3\">\n              <Lock className=\"text-[#ffc174] shrink-0 w-4 h-4 mt-0.5\" />\n              <span>\n                Use any name to simulate logging into the portal as a member. If you use <strong>Aaron</strong>, your saved data will reload!\n              </span>\n            </div>\n\n            <button\n              type=\"submit\"\n              className=\"w-full py-3.5 bg-[#f59e0b] hover:bg-[#f59e0b]/90 text-[#472a00] font-semibold rounded-lg flex items-center justify-center gap-2 transition-all active:scale-[0.98] shadow-lg shadow-[#f59e0b]/10\"\n            >\n              <span>Connect Member Session</span>\n              <UserPlus className=\"w-4 h-4\" />\n            </button>\n          </form>\n        </div>\n      </div>\n    );\n  }\n\n  return (\n    <div className=\"min-h-screen bg-[#0b1326] text-[#dae2fd] flex flex-col font-hanken relative overflow-x-hidden pb-28 pt-16\">\n      \n      {/* Toast Alert System */}\n      {toastMessage && (\n        <div id=\"toast-notif\" className=\"fixed top-20 left-1/2 -translate-x-1/2 z-50 w-[90%] max-w-sm bg-[#171f33] border border-[#f59e0b]/50 rounded-xl p-4 shadow-2xl shadow-[#f59e0b]/10 animate-bounce flex items-start gap-3\">\n          <div className=\"p-1 rounded-full bg-[#f59e0b]/10 text-[#ffc174]\">\n            <Sparkles className=\"w-5 h-5 animate-spin\" />\n          </div>\n          <div className=\"flex-1\">\n            <p className=\"text-xs font-mono text-[#ffc174] uppercase tracking-widest mb-0.5\">EMBER Portal Update</p>\n            <p className=\"text-sm text-[#dae2fd] font-medium leading-tight\">{toastMessage}</p>\n          </div>\n        </div>\n      )}\n\n      {/* Top App Bar */}\n      <header className=\"fixed top-0 left-0 w-full z-40 bg-[#0b1326] border-b border-[#2d3449]/40 flex justify-between items-center px-5 h-16\">\n        <div className=\"flex items-center gap-2 cursor-pointer\" onClick={() => setActiveTab(\'home\')}>\n          <Flame className=\"text-[#ffc174] w-7 h-7 fill-[#ffc174]\" />\n          <h1 className=\"font-extrabold text-xl tracking-tight text-[#ffc174] font-hanken\">EMBER</h1>\n        </div>\n        <div className=\"flex items-center gap-4\">\n          <button \n            id=\"btn-notif-bell\"\n            onClick={() => setShowNotificationDrawer(!showNotificationDrawer)}\n            className=\"hover:opacity-80 transition-opacity active:scale-95 text-[#d8c3ad] relative p-1.5 rounded-lg bg-[#131b2e] border border-[#2d3449]/30\"\n          >\n            <Bell className=\"w-5 h-5\" />\n            <span className=\"absolute top-1 right-1 w-2.5 h-2.5 rounded-full bg-[#f59e0b] border border-[#0b1326] animate-pulse\"></span>\n          </button>\n          \n          <div \n            onClick={() => setActiveTab(\'profile\')}\n            className=\"w-9 h-9 rounded-full border border-[#f59e0b]/50 bg-[#2d3449] cursor-pointer hover:ring-2 hover:ring-[#ffc174] transition-all p-0.5\"\n          >\n            <img \n              className=\"w-full h-full rounded-full object-cover\" \n              src={profile.avatar} \n              alt={profile.name} \n            />\n          </div>\n        </div>\n      </header>\n\n      {/* Persistent Notification Drawer overlay */}\n      {showNotificationDrawer && (\n        <div className=\"fixed inset-0 z-50 bg-[#060e20]/80 backdrop-blur-sm flex justify-end\">\n          <div className=\"w-full max-w-sm bg-[#171f33] h-full border-l border-[#2d3449] p-6 flex flex-col\">\n            <div className=\"flex justify-between items-center pb-4 border-b border-[#2d3449]\">\n              <div className=\"flex items-center gap-2\">\n                <Bell className=\"text-[#ffc174] w-5 h-5\" />\n                <h3 className=\"font-bold text-lg\">Announcements</h3>\n              </div>\n              <button \n                onClick={() => setShowNotificationDrawer(false)}\n                className=\"p-1.5 rounded-full hover:bg-[#2d3449] text-[#d8c3ad] transition-colors\"\n              >\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n            \n            <div className=\"flex-1 overflow-y-auto py-4 space-y-4\">\n              <div className=\"p-4 bg-[#2d3449]/30 border-l-4 border-[#f59e0b] rounded-r-lg\">\n                <span className=\"text-[10px] font-mono text-[#ffc174] bg-[#f59e0b]/10 py-0.5 px-2 rounded-full mb-2 inline-block\">LATEST</span>\n                <h4 className=\"font-semibold text-sm text-white mb-1\">Youth Fellowship Night This Friday!</h4>\n                <p className=\"text-xs text-[#d8c3ad] leading-relaxed\">Join us at 6:00 PM for group games and worship in the Main Sanctuary.</p>\n              </div>\n\n              <div className=\"p-4 bg-[#131b2e] border-l-4 border-[#bcc7de] rounded-r-lg\">\n                <span className=\"text-[10px] font-mono text-[#d8c3ad] bg-[#bcc7de]/10 py-0.5 px-2 rounded-full mb-2 inline-block\">POINTS ALERT</span>\n                <h4 className=\"font-semibold text-sm text-white mb-1\">Check-in Milestone Approaching!</h4>\n                <p className=\"text-xs text-[#d8c3ad] leading-relaxed\">You are only 3 check-ins away from hitting Level 13! Complete this cycle to unlock the Explorer Badge.</p>\n              </div>\n\n              <div className=\"p-4 bg-[#131b2e] border-l-4 border-[#ffbcb5] rounded-r-lg\">\n                <span className=\"text-[10px] font-mono text-[#ffbcb5] bg-[#ffbcb5]/10 py-0.5 px-2 rounded-full mb-2 inline-block\">SYSTEM</span>\n                <h4 className=\"font-semibold text-sm text-white mb-1\">Ember Portal V2.4.0 Live</h4>\n                <p className=\"text-xs text-[#d8c3ad] leading-relaxed\">New interactive prayer wall and Devotional sharing modules now active. Earn points for contributing!</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* Main Content Stage */}\n      <main className=\"flex-grow px-5 py-4 max-w-lg mx-auto w-full\">\n        \n        {/* TAB 1: HOME */}\n        {activeTab === \'home\' && (\n          <div className=\"space-y-8 animate-fade-in\">\n            \n            {/* Hero Section */}\n            <section className=\"space-y-2 mt-2\">\n              <p className=\"text-[#d8c3ad] font-mono text-xs uppercase tracking-widest\">Welcome Back</p>\n              <h2 className=\"text-3xl font-extrabold text-white leading-tight\">\n                Hello, {profile.name}!\n              </h2>\n              <div className=\"h-1.5 w-14 bg-[#f59e0b] rounded-full\"></div>\n            </section>\n\n            {/* Quick Actions Scroll Container */}\n            <section className=\"-mx-5 overflow-hidden\">\n              <div className=\"flex overflow-x-auto gap-4 px-5 pb-2 hide-scrollbar\">\n                \n                {/* Action Card 1 */}\n                <button \n                  onClick={() => handleQuickAction(\'devotional\')}\n                  className=\"flex-shrink-0 w-40 p-4 bg-[#171f33] border border-[#2d3449]/40 rounded-xl text-left hover:border-[#ffc174]/40 transition-all duration-300 group hover:translate-y-[-2px]\"\n                >\n                  <div className=\"w-10 h-10 rounded-xl bg-[#f59e0b]/10 flex items-center justify-center mb-4 text-[#ffc174] group-hover:bg-[#f59e0b]/20 transition-all\">\n                    <BookOpen className=\"w-5 h-5\" />\n                  </div>\n                  <p className=\"font-semibold text-sm text-[#dae2fd] leading-tight mb-1\">Share Devotion</p>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Submit Insight</p>\n                </button>\n\n                {/* Action Card 2 */}\n                <button \n                  onClick={() => handleQuickAction(\'testimony\')}\n                  className=\"flex-shrink-0 w-40 p-4 bg-[#171f33] border border-[#2d3449]/40 rounded-xl text-left hover:border-[#bcc7de]/40 transition-all duration-300 group hover:translate-y-[-2px]\"\n                >\n                  <div className=\"w-10 h-10 rounded-xl bg-[#bcc7de]/10 flex items-center justify-center mb-4 text-[#bcc7de] group-hover:bg-[#bcc7de]/20 transition-all\">\n                    <MessageSquare className=\"w-5 h-5\" />\n                  </div>\n                  <p className=\"font-semibold text-sm text-[#dae2fd] leading-tight mb-1\">Share Testimony</p>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Inspire Community</p>\n                </button>\n\n                {/* Action Card 3 */}\n                <button \n                  onClick={() => handleQuickAction(\'prayer\')}\n                  className=\"flex-shrink-0 w-40 p-4 bg-[#171f33] border border-[#2d3449]/40 rounded-xl text-left hover:border-[#ffbcb5]/40 transition-all duration-300 group hover:translate-y-[-2px]\"\n                >\n                  <div className=\"w-10 h-10 rounded-xl bg-[#ffbcb5]/10 flex items-center justify-center mb-4 text-[#ffbcb5] group-hover:bg-[#ffbcb5]/20 transition-all\">\n                    <Heart className=\"w-5 h-5\" />\n                  </div>\n                  <p className=\"font-semibold text-sm text-[#dae2fd] leading-tight mb-1\">Request Prayer</p>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Ember Wall</p>\n                </button>\n\n              </div>\n            </section>\n\n            {/* Latest Announcement Card */}\n            <section>\n              <div \n                onClick={() => setActiveTab(\'events\')}\n                className=\"relative overflow-hidden p-6 bg-[#171f33] border border-[#f59e0b]/20 rounded-2xl ember-glow hover:border-[#f59e0b]/40 cursor-pointer transition-all duration-300 group\"\n              >\n                <div className=\"absolute top-0 right-0 p-4 opacity-10 text-white group-hover:scale-110 transition-transform\">\n                  <Flame className=\"w-20 h-20 fill-[#ffc174]\" />\n                </div>\n                <div className=\"relative z-10 space-y-4\">\n                  <span className=\"inline-block font-mono text-[10px] text-[#ffc174] tracking-widest font-bold py-1 px-3 bg-[#f59e0b]/10 rounded-full border border-[#f59e0b]/20\">\n                    \360\237\223\242 LATEST ANNOUNCEMENT\n                  </span>\n                  <h3 className=\"font-extrabold text-xl text-white group-hover:text-[#ffc174] transition-colors\">\n                    Youth Fellowship Night This Friday!\n                  </h3>\n                  <div className=\"flex flex-wrap gap-4 text-[#d8c3ad] font-mono text-xs\">\n                    <div className=\"flex items-center gap-1.5\">\n                      <Clock className=\"w-4 h-4 text-[#ffc174]\" />\n                      <span>6:00 PM</span>\n                    </div>\n                    <div className=\"flex items-center gap-1.5\">\n                      <MapPin className=\"w-4 h-4 text-[#ffc174]\" />\n                      <span>Main Sanctuary</span>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </section>\n\n            {/* Upcoming Events Module */}\n            <section className=\"space-y-4\">\n              <div className=\"flex justify-between items-end\">\n                <h3 className=\"font-bold text-lg text-white\">Upcoming Events</h3>\n                <button \n                  onClick={() => setActiveTab(\'events\')}\n                  className=\"font-mono text-xs text-[#ffc174] hover:underline\"\n                >\n                  View All\n                </button>\n              </div>\n\n              {/* Event card (Ignite Youth Camp) */}\n              {events.slice(0, 1).map(ev => (\n                <div key={ev.id} className=\"group relative overflow-hidden bg-[#171f33] border border-[#2d3449]/40 rounded-2xl\">\n                  <div className=\"h-48 w-full overflow-hidden relative\">\n                    <img \n                      className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\" \n                      src={ev.image} \n                      alt={ev.title} \n                    />\n                    <div className=\"absolute inset-0 bg-gradient-to-t from-[#171f33] to-transparent\"></div>\n                  </div>\n                  \n                  <div className=\"p-5 space-y-4 relative -mt-4 bg-[#171f33] rounded-t-xl\">\n                    <div className=\"flex justify-between items-start gap-2\">\n                      <h4 className=\"font-extrabold text-lg text-white group-hover:text-[#ffc174] transition-colors\">\n                        {ev.title}\n                      </h4>\n                      <span className=\"shrink-0 font-mono text-xs bg-[#3e495d]/30 text-[#bcc7de] px-2.5 py-1 rounded border border-[#2d3449]\">\n                        {ev.date}\n                      </span>\n                    </div>\n                    \n                    <p className=\"text-[#d8c3ad] text-sm leading-relaxed\">\n                      {ev.description}\n                    </p>\n\n                    <div className=\"pt-2\">\n                      {ev.registered ? (\n                        <div className=\"w-full py-3 bg-[#3e495d]/30 border border-[#2d3449] rounded-xl flex items-center justify-center gap-2 text-[#bcc7de] font-bold text-sm\">\n                          <CheckCircle2 className=\"w-4 h-4 text-green-500\" />\n                          <span>Registered & Going!</span>\n                        </div>\n                      ) : (\n                        <button \n                          onClick={() => setShowEventRegisterModal(ev)}\n                          className=\"w-full py-3 bg-[#f59e0b] hover:bg-[#f59e0b]/90 text-[#472a00] font-bold text-sm rounded-xl hover:opacity-90 active:scale-[0.98] transition-all\"\n                        >\n                          Register Now (+{ev.pointsReward} Points)\n                        </button>\n                      )}\n                    </div>\n                  </div>\n                </div>\n              ))}\n            </section>\n\n            {/* Bento Grid Stats */}\n            <section className=\"space-y-4\">\n              <h3 className=\"font-bold text-lg text-white\">My Stats</h3>\n              <div className=\"grid grid-cols-2 gap-4\">\n                \n                <div \n                  onClick={() => setActiveTab(\'check-in\')}\n                  className=\"p-5 bg-[#222a3d] border border-[#2d3449]/40 rounded-xl flex flex-col justify-between cursor-pointer hover:border-[#ffc174]/20 transition-colors\"\n                >\n                  <p className=\"font-mono text-xs text-[#d8c3ad] mb-2 uppercase tracking-wider\">Check-ins</p>\n                  <div className=\"flex items-baseline gap-1\">\n                    <span className=\"text-3xl font-extrabold text-white\">{profile.checkIns}</span>\n                    <span className=\"text-xs text-[#ffc174] font-mono\">/ {profile.checkInsTarget}</span>\n                  </div>\n                  <div className=\"w-full bg-[#060e20] h-1.5 rounded-full mt-3 overflow-hidden\">\n                    <div \n                      className=\"bg-[#f59e0b] h-full rounded-full transition-all duration-500\" \n                      style={{ width: `${(profile.checkIns / profile.checkInsTarget) * 100}%` }}\n                    ></div>\n                  </div>\n                </div>\n\n                <div \n                  onClick={() => setActiveTab(\'profile\')}\n                  className=\"p-5 bg-[#222a3d] border border-[#2d3449]/40 rounded-xl flex flex-col justify-between cursor-pointer hover:border-[#ffc174]/20 transition-colors\"\n                >\n                  <p className=\"font-mono text-xs text-[#d8c3ad] mb-2 uppercase tracking-wider\">Points Balance</p>\n                  <div className=\"flex items-center gap-1.5\">\n                    <span className=\"text-3xl font-extrabold text-white\">{profile.points}</span>\n                    <Sparkles className=\"text-[#ffc174] w-5 h-5 fill-[#ffc174] animate-pulse\" />\n                  </div>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/50 mt-3 uppercase tracking-wider\">Level {profile.level} Member</p>\n                </div>\n\n              </div>\n            </section>\n\n          </div>\n        )}\n\n        {/* TAB 2: EVENTS */}\n        {activeTab === \'events\' && (\n          <div className=\"space-y-6 animate-fade-in\">\n            <div className=\"space-y-1\">\n              <h2 className=\"text-2xl font-extrabold text-white\">Ember Youth Events</h2>\n              <p className=\"text-[#d8c3ad] text-sm\">Stay connected and join our upcoming weekend fellowships, camps, and summits.</p>\n            </div>\n\n            <div className=\"space-y-6\">\n              {events.map(ev => (\n                <div key={ev.id} className=\"bg-[#171f33] border border-[#2d3449]/40 rounded-2xl overflow-hidden hover:border-[#ffc174]/20 transition-colors\">\n                  <div className=\"h-40 w-full relative overflow-hidden\">\n                    <img className=\"w-full h-full object-cover\" src={ev.image} alt={ev.title} />\n                    <div className=\"absolute inset-0 bg-gradient-to-t from-[#171f33] to-transparent\"></div>\n                  </div>\n\n                  <div className=\"p-5 space-y-3 relative -mt-4 bg-[#171f33] rounded-t-xl\">\n                    <div className=\"flex justify-between items-start gap-2\">\n                      <h3 className=\"font-extrabold text-lg text-white\">{ev.title}</h3>\n                      <span className=\"shrink-0 font-mono text-[10px] bg-[#3e495d]/30 text-[#bcc7de] px-2 py-0.5 rounded border border-[#2d3449]\">\n                        {ev.date}\n                      </span>\n                    </div>\n\n                    <p className=\"text-xs text-[#d8c3ad] leading-relaxed\">{ev.description}</p>\n\n                    <div className=\"flex flex-wrap gap-y-2 gap-x-4 text-xs font-mono text-[#d8c3ad]/80 pt-1\">\n                      <div className=\"flex items-center gap-1\">\n                        <Clock className=\"w-3.5 h-3.5 text-[#ffc174]\" />\n                        <span>{ev.time}</span>\n                      </div>\n                      <div className=\"flex items-center gap-1\">\n                        <MapPin className=\"w-3.5 h-3.5 text-[#ffc174]\" />\n                        <span>{ev.location}</span>\n                      </div>\n                    </div>\n\n                    <div className=\"flex justify-between items-center gap-4 pt-3 border-t border-[#2d3449]/30\">\n                      <div>\n                        <p className=\"text-[10px] text-[#d8c3ad]/50 uppercase tracking-widest font-mono\">Admission</p>\n                        <p className=\"text-xs font-bold text-white\">{ev.price}</p>\n                      </div>\n\n                      {ev.registered ? (\n                        <div className=\"px-4 py-2 bg-green-500/10 border border-green-500/30 text-green-400 font-bold text-xs rounded-lg flex items-center gap-1.5\">\n                          <CheckCircle2 className=\"w-3.5 h-3.5\" />\n                          <span>Going</span>\n                        </div>\n                      ) : (\n                        <button \n                          onClick={() => setShowEventRegisterModal(ev)}\n                          className=\"px-4 py-2 bg-[#f59e0b] hover:bg-[#f59e0b]/90 text-[#472a00] font-bold text-xs rounded-lg transition-all\"\n                        >\n                          RSVP Now\n                        </button>\n                      )}\n                    </div>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* TAB 3: CHECK-IN */}\n        {activeTab === \'check-in\' && (\n          <div className=\"space-y-6 flex flex-col items-center justify-center animate-fade-in min-h-[70dvh] relative\">\n            \n            {/* Identity Card Container */}\n            <div className=\"w-full bg-[#171f33] border border-[#2d3449]/40 rounded-2xl p-6 flex flex-col items-center relative z-10 ember-glow text-center space-y-6\">\n              \n              {/* Circular Avatar Section with Active Status */}\n              <div className=\"relative\">\n                <div className=\"w-24 h-24 rounded-full border-4 border-[#f59e0b] p-1 bg-[#0b1326] overflow-hidden\">\n                  <img className=\"w-full h-full object-cover rounded-full\" src={profile.avatar} alt={profile.name} />\n                </div>\n                <div className=\"absolute -bottom-1 -right-1 bg-[#ffc174] text-[#472a00] px-2.5 py-0.5 rounded-full font-mono text-[10px] font-bold border-2 border-[#171f33]\">\n                  ACTIVE\n                </div>\n              </div>\n\n              {/* Name and ID */}\n              <div>\n                <h2 className=\"text-2xl font-extrabold text-white\">{profile.name}</h2>\n                <p className=\"text-xs font-mono text-[#d8c3ad] uppercase tracking-widest mt-1\">ID: {profile.id}</p>\n              </div>\n\n              {/* Dynamic QR Scanner Grid Simulation */}\n              <div className=\"relative\">\n                <div className={`p-4 bg-white rounded-2xl border-4 ${checkInScanning ? \'border-[#f59e0b] animate-pulse\' : \'border-transparent\'} transition-all`}>\n                  <div className=\"w-[180px] h-[180px] bg-white flex flex-col justify-between relative overflow-hidden\">\n                    \n                    {/* Mock complex QR code blocks */}\n                    <div className=\"w-full h-full grid grid-cols-5 grid-rows-5 gap-1.5 opacity-90 p-1\">\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-white\"></div>\n\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-white\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                      <div className=\"bg-black rounded-sm\"></div>\n                    </div>\n\n                    {/* QR center overlay logo */}\n                    <div className=\"absolute inset-0 flex items-center justify-center\">\n                      <div className=\"bg-white p-2 rounded-lg border border-[#2d3449]/20 shadow-lg\">\n                        <Flame className=\"text-[#f59e0b] w-8 h-8 fill-[#f59e0b]\" />\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Laser scan line overlay during checkin simulation */}\n                {checkInScanning && (\n                  <div className=\"absolute inset-x-0 h-1 bg-red-500 shadow-lg shadow-red-500 top-1/2 -translate-y-1/2 animate-bounce z-20\"></div>\n                )}\n              </div>\n\n              {/* Instructions */}\n              <div className=\"max-w-[280px]\">\n                {checkInSuccess ? (\n                  <p className=\"text-green-400 font-bold text-sm animate-pulse\">\n                    \342\234\223 Check-in Verified! Welcome to the group!\n                  </p>\n                ) : (\n                  <p className=\"text-sm text-[#d8c3ad]\">\n                    Present this screen to a Youth Leader to register attendance, or click below to simulate.\n                  </p>\n                )}\n              </div>\n\n              {/* Action scanner triggers */}\n              <div className=\"w-full\">\n                {checkInScanning ? (\n                  <button className=\"w-full py-3 bg-[#3e495d]/30 text-[#bcc7de] font-bold text-sm rounded-xl cursor-not-allowed flex items-center justify-center gap-2\">\n                    <span className=\"w-4 h-4 border-2 border-t-transparent border-[#bcc7de] rounded-full animate-spin\"></span>\n                    <span>Transmitting Secure Code...</span>\n                  </button>\n                ) : justCheckedInToday ? (\n                  <div className=\"w-full py-3 bg-green-500/10 border border-green-500/20 text-green-400 font-bold text-sm rounded-xl flex items-center justify-center gap-2\">\n                    <CheckCircle2 className=\"w-4 h-4 text-green-500\" />\n                    <span>Checked in for Today! (+30 XP)</span>\n                  </div>\n                ) : (\n                  <button \n                    onClick={handleCheckInScan}\n                    className=\"w-full py-3 bg-[#f59e0b] hover:bg-[#f59e0b]/90 text-[#472a00] font-bold text-sm rounded-xl transition-all shadow-lg active:scale-[0.98]\"\n                  >\n                    Simulate QR Code Scan\n                  </button>\n                )}\n              </div>\n\n              {/* Stats Chips */}\n              <div className=\"flex gap-3 justify-center w-full\">\n                <span className=\"bg-[#3e495d]/20 border border-[#2d3449] text-[#bcc7de] px-4 py-1.5 rounded-full font-mono text-xs font-bold\">\n                  LEVEL {profile.level}\n                </span>\n                <span className=\"bg-[#3e495d]/20 border border-[#2d3449] text-[#bcc7de] px-4 py-1.5 rounded-full font-mono text-xs font-bold flex items-center gap-1\">\n                  <Zap className=\"w-3.5 h-3.5 text-[#ffc174] fill-[#ffc174]\" />\n                  STREAK: {profile.streak}\n                </span>\n              </div>\n\n            </div>\n\n            {/* Subtle bottom indicator */}\n            <div className=\"opacity-50 flex items-center gap-2 mt-4\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-green-500 animate-pulse\"></span>\n              <span className=\"font-mono text-xs text-[#d8c3ad] tracking-widest uppercase\">Secure Dynamic Code Active</span>\n            </div>\n\n          </div>\n        )}\n\n        {/* TAB 4: POSTS (SHARE YOUR FIRE) */}\n        {activeTab === \'posts\' && (\n          <div className=\"space-y-6 animate-fade-in\">\n            <div className=\"space-y-2\">\n              <h2 className=\"text-2xl font-extrabold text-white\">Share Your Fire</h2>\n              <p className=\"text-[#d8c3ad] text-sm\">\n                Contribute to the EMBER community with your latest spiritual insights, Bible studies, or personal journeys.\n              </p>\n            </div>\n\n            {/* Main Form Canvas */}\n            <form onSubmit={handlePostSubmit} className=\"bg-[#171f33]/70 backdrop-blur-md rounded-2xl p-6 border border-[#2d3449]/40 space-y-6 ember-glow\">\n              \n              {/* Content Type Toggle Segmented Switch */}\n              <div className=\"space-y-2\">\n                <label className=\"block font-mono text-xs text-[#d8c3ad] uppercase tracking-wider\">\n                  Content Type\n                </label>\n                <div className=\"flex bg-[#222a3d] p-1 rounded-xl w-full\">\n                  <button\n                    type=\"button\"\n                    onClick={() => setPostType(\'devotional\')}\n                    className={`flex-1 py-2.5 rounded-lg font-bold text-sm transition-all duration-300 ${\n                      postType === \'devotional\'\n                        ? \'bg-[#f59e0b] text-[#472a00] shadow-md\'\n                        : \'text-[#d8c3ad] hover:text-white\'\n                    }`}\n                  >\n                    Devotional\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={() => setPostType(\'testimony\')}\n                    className={`flex-1 py-2.5 rounded-lg font-bold text-sm transition-all duration-300 ${\n                      postType === \'testimony\'\n                        ? \'bg-[#f59e0b] text-[#472a00] shadow-md\'\n                        : \'text-[#d8c3ad] hover:text-white\'\n                    }`}\n                  >\n                    Testimony\n                  </button>\n                </div>\n              </div>\n\n              {/* Title Input */}\n              <div className=\"space-y-2\">\n                <label className=\"block font-mono text-xs text-[#d8c3ad] uppercase tracking-wider\" htmlFor=\"post-title\">\n                  Submission Title\n                </label>\n                <input\n                  id=\"post-title\"\n                  type=\"text\"\n                  value={postTitle}\n                  onChange={(e) => setPostTitle(e.target.value)}\n                  className=\"w-full bg-[#060e20] border border-[#2d3449]/50 rounded-xl py-3 px-4 text-[#dae2fd] placeholder-[#aeb9d0]/30 focus:outline-none focus:ring-1 focus:ring-[#ffc174] focus:border-[#ffc174] transition-all\"\n                  placeholder={postType === \'devotional\' ? \"Enter a catchy title...\" : \"My winter camp break...\"}\n                  required\n                />\n              </div>\n\n              {/* Body text area */}\n              <div className=\"space-y-2\">\n                <label className=\"block font-mono text-xs text-[#d8c3ad] uppercase tracking-wider\" htmlFor=\"post-body\">\n                  Message Body\n                </label>\n                <textarea\n                  id=\"post-body\"\n                  rows={6}\n                  value={postBody}\n                  onChange={(e) => setPostBody(e.target.value)}\n                  className=\"w-full bg-[#060e20] border border-[#2d3449]/50 rounded-xl py-3 px-4 text-[#dae2fd] placeholder-[#aeb9d0]/30 focus:outline-none focus:ring-1 focus:ring-[#ffc174] focus:border-[#ffc174] transition-all resize-none\"\n                  placeholder={\n                    postType === \'devotional\'\n                      ? \"What daily spiritual insight or scripture study is on your heart? Share it with the youth community...\"\n                      : \"How has God been working in your life recently? Share your personal journey...\"\n                  }\n                  required\n                />\n              </div>\n\n              {/* Warning/Guideline banner */}\n              <div className=\"p-4 bg-[#f59e0b]/10 border border-[#f59e0b]/20 rounded-xl flex gap-3 text-xs leading-relaxed text-[#d8c3ad]\">\n                <AlertTriangle className=\"text-[#ffc174] shrink-0 w-5 h-5\" />\n                <p>\n                  Submissions undergo leader validation before visibility online. Please ensure your content aligns with our community values. Approved submissions earn XP and badges!\n                </p>\n              </div>\n\n              {/* Submit button */}\n              <div>\n                {submittingPost ? (\n                  <button type=\"button\" className=\"w-full py-4 bg-[#3e495d]/30 text-[#bcc7de] font-bold rounded-xl cursor-not-allowed flex items-center justify-center gap-2\">\n                    <span className=\"w-4 h-4 border-2 border-t-transparent border-[#bcc7de] rounded-full animate-spin\"></span>\n                    <span>Auditing Submission Guidelines...</span>\n                  </button>\n                ) : postSuccess ? (\n                  <button type=\"button\" className=\"w-full py-4 bg-green-500/20 border border-green-500/40 text-green-400 font-bold rounded-xl flex items-center justify-center gap-2 animate-pulse\">\n                    <CheckCircle2 className=\"w-5 h-5\" />\n                    <span>Sent for Review! (+25 XP)</span>\n                  </button>\n                ) : (\n                  <button\n                    type=\"submit\"\n                    className=\"w-full bg-[#f59e0b] hover:bg-[#f59e0b]/90 text-[#472a00] font-bold py-4 rounded-xl flex items-center justify-center gap-2 transition-all active:scale-[0.98] shadow-lg shadow-[#f59e0b]/10\"\n                  >\n                    <span>Submit for Review</span>\n                    <Send className=\"w-4 h-4\" />\n                  </button>\n                )}\n              </div>\n\n            </form>\n\n            <div className=\"text-center opacity-50 pt-2\">\n              <span className=\"font-mono text-xs text-[#d8c3ad]\">EMBER PORTAL V2.4.0</span>\n            </div>\n          </div>\n        )}\n\n        {/* TAB 5: PRAYER WALL */}\n        {activeTab === \'prayers\' && (\n          <div className=\"space-y-6 animate-fade-in\">\n            <div className=\"flex justify-between items-center\">\n              <div className=\"space-y-1\">\n                <h2 className=\"text-2xl font-extrabold text-white\">Ember Prayer Wall</h2>\n                <p className=\"text-[#d8c3ad] text-sm\">Stand together. Ask for prayer and intercede for your fellow brothers & sisters.</p>\n              </div>\n            </div>\n\n            {/* Quick Share Form Trigger */}\n            <button \n              onClick={() => setShowNewPrayerModal(true)}\n              className=\"w-full py-4 bg-[#171f33] border border-[#ffbcb5]/20 hover:border-[#ffbcb5]/40 rounded-xl flex items-center justify-center gap-2 text-[#ffbcb5] font-bold transition-all text-sm group\"\n            >\n              <Plus className=\"w-4 h-4 group-hover:rotate-90 transition-transform\" />\n              <span>Share a Prayer Request (+15 Points)</span>\n            </button>\n\n            {/* New Prayer Request Modal */}\n            {showNewPrayerModal && (\n              <div className=\"fixed inset-0 z-50 bg-[#060e20]/80 backdrop-blur-sm flex justify-center items-center p-5\">\n                <div className=\"w-full max-w-md bg-[#171f33] border border-[#2d3449] rounded-2xl p-6 space-y-4 shadow-2xl\">\n                  <div className=\"flex justify-between items-center pb-2 border-b border-[#2d3449]\">\n                    <h3 className=\"font-bold text-lg text-[#ffbcb5]\">Ask for Prayer</h3>\n                    <button onClick={() => setShowNewPrayerModal(false)} className=\"text-[#d8c3ad] hover:text-white p-1\">\n                      <X className=\"w-5 h-5\" />\n                    </button>\n                  </div>\n\n                  <form onSubmit={handlePrayerSubmit} className=\"space-y-4\">\n                    <div className=\"space-y-2\">\n                      <label className=\"block text-xs uppercase font-mono text-[#d8c3ad] tracking-widest\" htmlFor=\"prayer-content\">\n                        What can our youth community pray about?\n                      </label>\n                      <textarea\n                        id=\"prayer-content\"\n                        rows={4}\n                        value={newPrayerContent}\n                        onChange={(e) => setNewPrayerContent(e.target.value)}\n                        className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-xl p-3.5 text-sm text-[#dae2fd] focus:outline-none focus:ring-1 focus:ring-[#ffbcb5]\"\n                        placeholder=\"Share your trials, struggles, or praises. Be anonymous if preferred or sign under your username.\"\n                        required\n                      ></textarea>\n                    </div>\n\n                    <button \n                      type=\"submit\"\n                      className=\"w-full py-3 bg-[#ffbcb5] text-[#690007] hover:opacity-90 font-bold rounded-xl text-sm\"\n                    >\n                      Post to Prayer Wall\n                    </button>\n                  </form>\n                </div>\n              </div>\n            )}\n\n            {/* Prayer Cards list */}\n            <div className=\"space-y-4\">\n              {prayers.map(p => (\n                <div key={p.id} className=\"bg-[#171f33] border border-[#2d3449]/30 rounded-2xl p-5 space-y-4\">\n                  <div className=\"flex items-center gap-3\">\n                    <img className=\"w-9 h-9 rounded-full object-cover border border-[#2d3449]\" src={p.avatar} alt={p.author} />\n                    <div className=\"flex-1\">\n                      <h4 className=\"font-bold text-sm text-white\">{p.author}</h4>\n                      <p className=\"text-[10px] text-[#d8c3ad]/50 font-mono uppercase tracking-widest\">{p.timeAgo}</p>\n                    </div>\n                  </div>\n\n                  <p className=\"text-sm text-[#dae2fd] leading-relaxed italic\">\n                    \"{p.content}\"\n                  </p>\n\n                  <div className=\"flex justify-between items-center pt-3 border-t border-[#2d3449]/20\">\n                    <div className=\"flex items-center gap-1.5 text-xs text-[#d8c3ad]/80 font-mono\">\n                      <Flame className=\"w-4 h-4 text-[#ffbcb5] fill-[#ffbcb5]\" />\n                      <span>{p.prayersCount} intercessions</span>\n                    </div>\n\n                    <button \n                      onClick={() => handlePrayForPerson(p.id)}\n                      className={`px-4 py-2 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5 ${\n                        p.hasPrayed \n                          ? \'bg-red-500/10 border border-red-500/30 text-red-400\'\n                          : \'bg-[#ffbcb5]/10 hover:bg-[#ffbcb5]/20 text-[#ffbcb5] border border-[#ffbcb5]/20\'\n                      }`}\n                    >\n                      <Heart className={`w-3.5 h-3.5 ${p.hasPrayed ? \'fill-red-400 text-red-400\' : \'\'}`} />\n                      <span>{p.hasPrayed ? \'Praying!\' : \'Pray for them\'}</span>\n                    </button>\n                  </div>\n                </div>\n              ))}\n            </div>\n          </div>\n        )}\n\n        {/* TAB 6: PROFILE */}\n        {activeTab === \'profile\' && (\n          <div className=\"space-y-8 animate-fade-in\">\n            \n            {/* Header Section */}\n            <section className=\"flex flex-col items-center text-center space-y-4 mt-2\">\n              <div className=\"relative group\">\n                <div className=\"absolute inset-0 rounded-full bg-[#f59e0b]/20 blur-xl group-hover:bg-[#f59e0b]/30 transition-all\"></div>\n                \n                {/* Profile Image */}\n                <div className=\"relative w-28 h-28 rounded-full border-4 border-[#222a3d] overflow-hidden p-1 bg-[#0b1326]\">\n                  <img className=\"w-full h-full object-cover rounded-full\" src={profile.avatar} alt={profile.name} />\n                </div>\n                \n                {/* Active Indicator */}\n                <div className=\"absolute bottom-1 right-1 w-7 h-7 rounded-full bg-[#0b1326] border-2 border-[#2d3449] flex items-center justify-center\">\n                  <div className=\"w-3 h-3 rounded-full bg-green-500 animate-pulse\"></div>\n                </div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <h2 className=\"text-2xl font-extrabold text-white\">{profile.name}</h2>\n                <p className=\"text-xs font-mono text-[#d8c3ad] bg-[#2d3449]/60 px-3 py-1 rounded-full border border-[#2d3449] inline-block\">\n                  {profile.id}\n                </p>\n                <div className=\"mt-3 block\">\n                  <div className=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-[#f59e0b]/10 border border-[#f59e0b]/30 text-[#ffc174] font-mono text-[10px] font-bold uppercase tracking-wider\">\n                    <Award className=\"w-3.5 h-3.5\" />\n                    <span>Level {profile.level} Explorer</span>\n                  </div>\n                </div>\n                {profile.bio && (\n                  <p className=\"text-xs text-[#d8c3ad]/80 max-w-sm pt-2 leading-relaxed italic\">\n                    \"{profile.bio}\"\n                  </p>\n                )}\n              </div>\n            </section>\n\n            {/* Stats Bento Grid */}\n            <section className=\"grid grid-cols-2 gap-4\">\n              \n              <div className=\"bg-[#171f33] p-4 rounded-xl border border-[#2d3449]/40 flex items-center gap-3 shadow-md\">\n                <div className=\"w-10 h-10 rounded-lg bg-[#f59e0b]/10 text-[#ffc174] flex items-center justify-center shrink-0\">\n                  <Sparkles className=\"w-5 h-5 fill-[#ffc174]\" />\n                </div>\n                <div>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Points</p>\n                  <p className=\"text-lg font-bold text-white\">{profile.points}</p>\n                </div>\n              </div>\n\n              <div className=\"bg-[#171f33] p-4 rounded-xl border border-[#2d3449]/40 flex items-center gap-3 shadow-md\">\n                <div className=\"w-10 h-10 rounded-lg bg-[#bcc7de]/10 text-[#bcc7de] flex items-center justify-center shrink-0\">\n                  <QrCode className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Check-ins</p>\n                  <p className=\"text-lg font-bold text-white\">{profile.checkIns}</p>\n                </div>\n              </div>\n\n              <div className=\"bg-[#171f33] p-4 rounded-xl border border-[#2d3449]/40 flex items-center gap-3 shadow-md\">\n                <div className=\"w-10 h-10 rounded-lg bg-[#ffbcb5]/10 text-[#ffbcb5] flex items-center justify-center shrink-0\">\n                  <Heart className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Prayers Shared</p>\n                  <p className=\"text-lg font-bold text-white\">{profile.prayersShared}</p>\n                </div>\n              </div>\n\n              <div className=\"bg-[#171f33] p-4 rounded-xl border border-[#2d3449]/40 flex items-center gap-3 shadow-md\">\n                <div className=\"w-10 h-10 rounded-lg bg-[#ffc174]/10 text-[#ffc174] flex items-center justify-center shrink-0\">\n                  <MessageSquare className=\"w-5 h-5\" />\n                </div>\n                <div>\n                  <p className=\"text-[10px] font-mono text-[#d8c3ad]/60 uppercase tracking-wider\">Posts</p>\n                  <p className=\"text-lg font-bold text-white\">{profile.postsCount}</p>\n                </div>\n              </div>\n\n            </section>\n\n            {/* Menu List */}\n            <section className=\"space-y-3\">\n              <h4 className=\"font-mono text-xs text-[#d8c3ad] uppercase tracking-widest mb-4 px-1\">Account & Content</h4>\n\n              {/* Menu Item 1: Edit Profile */}\n              <button \n                onClick={() => setShowEditProfileModal(true)}\n                className=\"w-full flex items-center justify-between p-4 bg-[#131b2e] rounded-xl border border-[#2d3449]/10 hover:bg-[#171f33] transition-colors group active:scale-[0.98] text-left\"\n              >\n                <div className=\"flex items-center gap-4\">\n                  <div className=\"w-10 h-10 flex items-center justify-center rounded-xl bg-[#2d3449] text-[#ffc174]\">\n                    <User className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <p className=\"font-bold text-sm text-[#dae2fd]\">Edit Profile</p>\n                    <p className=\"text-[11px] text-[#d8c3ad]/60 font-mono\">Update your username, avatar or bio</p>\n                  </div>\n                </div>\n                <ChevronRight className=\"w-5 h-5 text-[#d8c3ad] group-hover:translate-x-1 transition-transform\" />\n              </button>\n\n              {/* Menu Item 2: My Contributions */}\n              <button \n                onClick={() => setShowMyContributionsModal(true)}\n                className=\"w-full flex items-center justify-between p-4 bg-[#131b2e] rounded-xl border border-[#2d3449]/10 hover:bg-[#171f33] transition-colors group active:scale-[0.98] text-left\"\n              >\n                <div className=\"flex items-center gap-4\">\n                  <div className=\"w-10 h-10 flex items-center justify-center rounded-xl bg-[#2d3449] text-[#ffc174]\">\n                    <FileText className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <p className=\"font-bold text-sm text-[#dae2fd]\">My Contributions</p>\n                    <p className=\"text-[11px] text-[#d8c3ad]/60 font-mono\">Testimonies & Devotions status</p>\n                  </div>\n                </div>\n                <ChevronRight className=\"w-5 h-5 text-[#d8c3ad] group-hover:translate-x-1 transition-transform\" />\n              </button>\n\n              {/* Menu Item 3: Notification Toggles */}\n              <div className=\"flex items-center justify-between p-4 bg-[#131b2e] rounded-xl border border-[#2d3449]/10 text-left\">\n                <div className=\"flex items-center gap-4\">\n                  <div className=\"w-10 h-10 flex items-center justify-center rounded-xl bg-[#2d3449] text-[#ffc174]\">\n                    <Bell className=\"w-5 h-5\" />\n                  </div>\n                  <div>\n                    <p className=\"font-bold text-sm text-[#dae2fd]\">Notification Settings</p>\n                    <p className=\"text-[11px] text-[#d8c3ad]/60 font-mono\">Mute or enable announcements</p>\n                  </div>\n                </div>\n                <label className=\"relative inline-flex items-center cursor-pointer\">\n                  <input type=\"checkbox\" defaultChecked className=\"sr-only peer\" />\n                  <div className=\"w-9 h-5 bg-[#2d3449] peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[\'\'] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-[#f59e0b]\"></div>\n                </label>\n              </div>\n\n            </section>\n\n            {/* Logout Button */}\n            <button \n              onClick={handleLogout}\n              className=\"w-full py-4 rounded-xl border border-[#ffbcb5]/20 text-[#ffbcb5] flex items-center justify-center gap-2 font-bold hover:bg-red-500/5 transition-all text-sm active:scale-[0.98]\"\n            >\n              <LogOut className=\"w-4 h-4\" />\n              <span>Logout Simulated Session</span>\n            </button>\n\n          </div>\n        )}\n\n      </main>\n\n      {/* Slide-Up Modals & Sub-Flows */}\n      \n      {/* 1. Edit Profile Modal */}\n      {showEditProfileModal && (\n        <div className=\"fixed inset-0 z-50 bg-[#060e20]/80 backdrop-blur-sm flex justify-center items-center p-5\">\n          <div className=\"w-full max-w-md bg-[#171f33] border border-[#2d3449] rounded-2xl p-6 space-y-6\">\n            <div className=\"flex justify-between items-center pb-2 border-b border-[#2d3449]\">\n              <h3 className=\"font-bold text-lg text-white\">Edit Ember Profile</h3>\n              <button onClick={() => setShowEditProfileModal(false)} className=\"text-[#d8c3ad] p-1\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <div className=\"space-y-4\">\n              <div>\n                <label className=\"block text-xs font-mono uppercase tracking-widest text-[#d8c3ad] mb-2\">Display Username</label>\n                <input \n                  type=\"text\" \n                  value={profile.name}\n                  onChange={(e) => setProfile({ ...profile, name: e.target.value })}\n                  className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-xl py-3 px-4 text-sm text-[#dae2fd] focus:outline-none\"\n                />\n              </div>\n\n              <div>\n                <label className=\"block text-xs font-mono uppercase tracking-widest text-[#d8c3ad] mb-2\">Avatar URL</label>\n                <input \n                  type=\"text\" \n                  value={profile.avatar}\n                  onChange={(e) => setProfile({ ...profile, avatar: e.target.value })}\n                  className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-xl py-2 px-3 text-xs text-[#dae2fd] focus:outline-none\"\n                />\n              </div>\n\n              <div>\n                <label className=\"block text-xs font-mono uppercase tracking-widest text-[#d8c3ad] mb-2\">Personal Bio Quote</label>\n                <textarea \n                  rows={3}\n                  value={profile.bio || \'\'}\n                  onChange={(e) => setProfile({ ...profile, bio: e.target.value })}\n                  className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-xl py-3 px-4 text-sm text-[#dae2fd] focus:outline-none resize-none\"\n                />\n              </div>\n            </div>\n\n            <button \n              onClick={() => {\n                setShowEditProfileModal(false);\n                triggerToast(\'Ember member profile updated successfully!\');\n              }}\n              className=\"w-full py-3 bg-[#f59e0b] text-[#472a00] font-bold rounded-xl text-sm\"\n            >\n              Save Profile Changes\n            </button>\n          </div>\n        </div>\n      )}\n\n      {/* 2. My Contributions Drawer */}\n      {showMyContributionsModal && (\n        <div className=\"fixed inset-0 z-50 bg-[#060e20]/80 backdrop-blur-sm flex justify-center items-center p-5\">\n          <div className=\"w-full max-w-md bg-[#171f33] border border-[#2d3449] rounded-2xl p-6 space-y-4 max-h-[80vh] flex flex-col\">\n            <div className=\"flex justify-between items-center pb-2 border-b border-[#2d3449]\">\n              <h3 className=\"font-bold text-lg text-white\">My Contributions</h3>\n              <button onClick={() => setShowMyContributionsModal(false)} className=\"text-[#d8c3ad] p-1\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <div className=\"flex-1 overflow-y-auto space-y-4 py-2\">\n              {submittedPosts.map(p => (\n                <div key={p.id} className=\"p-4 bg-[#060e20] border border-[#2d3449] rounded-xl space-y-2\">\n                  <div className=\"flex justify-between items-center\">\n                    <span className=\"text-[10px] font-mono uppercase bg-[#f59e0b]/10 text-[#ffc174] px-2 py-0.5 rounded-full border border-[#f59e0b]/20\">\n                      {p.type}\n                    </span>\n                    <span className={`text-[10px] font-mono px-2 py-0.5 rounded-full ${\n                      p.status === \'Approved\' ? \'bg-green-500/10 text-green-400\' : \'bg-yellow-500/10 text-yellow-400\'\n                    }`}>\n                      \342\200\242 {p.status}\n                    </span>\n                  </div>\n                  <h4 className=\"font-bold text-sm text-white\">{p.title}</h4>\n                  <p className=\"text-xs text-[#d8c3ad]/80 leading-relaxed italic\">\"{p.body}\"</p>\n                  <p className=\"text-[9px] text-[#d8c3ad]/40 font-mono pt-1 text-right\">{p.timestamp}</p>\n                </div>\n              ))}\n            </div>\n          </div>\n        </div>\n      )}\n\n      {/* 3. Event Registration Modal */}\n      {showEventRegisterModal && (\n        <div className=\"fixed inset-0 z-50 bg-[#060e20]/80 backdrop-blur-sm flex justify-center items-center p-5\">\n          <div className=\"w-full max-w-md bg-[#171f33] border border-[#2d3449] rounded-2xl p-6 space-y-4\">\n            <div className=\"flex justify-between items-center pb-2 border-b border-[#2d3449]\">\n              <div>\n                <h3 className=\"font-extrabold text-lg text-[#ffc174]\">{showEventRegisterModal.title}</h3>\n                <p className=\"text-xs text-[#bcc7de] font-mono uppercase\">Ticket Registration</p>\n              </div>\n              <button onClick={() => setShowEventRegisterModal(null)} className=\"text-[#d8c3ad] p-1\">\n                <X className=\"w-5 h-5\" />\n              </button>\n            </div>\n\n            <div className=\"p-3 bg-[#060e20] rounded-xl border border-[#2d3449] flex gap-3 items-center\">\n              <Sparkles className=\"w-5 h-5 text-[#ffc174] fill-[#ffc174]\" />\n              <div className=\"text-xs\">\n                <p className=\"font-bold text-white\">Points Reward on Attendance</p>\n                <p className=\"text-[#d8c3ad]\">Complete this registration to reserve and claim +{showEventRegisterModal.pointsReward} XP!</p>\n              </div>\n            </div>\n\n            <form \n              onSubmit={(e) => {\n                e.preventDefault();\n                handleRegisterEvent(showEventRegisterModal.id, {});\n              }}\n              className=\"space-y-4\"\n            >\n              <div className=\"grid grid-cols-2 gap-3\">\n                <div className=\"space-y-1.5\">\n                  <label className=\"block text-[10px] font-mono text-[#d8c3ad] uppercase\">T-Shirt Size</label>\n                  <select className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-lg p-2 text-xs text-[#dae2fd]\" required>\n                    <option>S</option>\n                    <option>M</option>\n                    <option selected>L</option>\n                    <option>XL</option>\n                    <option>XXL</option>\n                  </select>\n                </div>\n                <div className=\"space-y-1.5\">\n                  <label className=\"block text-[10px] font-mono text-[#d8c3ad] uppercase\">Dietary Pref</label>\n                  <select className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-lg p-2 text-xs text-[#dae2fd]\" required>\n                    <option selected>None</option>\n                    <option>Vegetarian</option>\n                    <option>Halal</option>\n                    <option>Gluten Free</option>\n                    <option>Nut Allergy</option>\n                  </select>\n                </div>\n              </div>\n\n              <div className=\"space-y-1.5\">\n                <label className=\"block text-[10px] font-mono text-[#d8c3ad] uppercase\">Emergency Contact Number</label>\n                <input \n                  type=\"tel\" \n                  placeholder=\"+1 (555) 019-2834\"\n                  className=\"w-full bg-[#060e20] border border-[#2d3449] rounded-lg p-2 text-xs text-[#dae2fd]\"\n                  required\n                />\n              </div>\n\n              <button \n                type=\"submit\"\n                className=\"w-full py-3 bg-[#f59e0b] text-[#472a00] font-extrabold rounded-xl text-sm transition-all hover:opacity-90 active:scale-[0.98]\"\n              >\n                Confirm Spot & RSVP\n              </button>\n            </form>\n          </div>\n        </div>\n      )}\n\n      {/* Bottom Tab Bar navigation */}\n      <nav className=\"fixed bottom-0 left-0 w-full z-40 bg-[#171f33] border-t border-[#2d3449]/40 shadow-2xl flex justify-around items-end pb-5 pt-2 px-2 rounded-t-2xl\">\n        \n        {/* Tab 1: Home */}\n        <button \n          id=\"tab-home\"\n          onClick={() => setActiveTab(\'home\')}\n          className={`flex flex-col items-center justify-center cursor-pointer transition-all duration-200 px-4 py-1.5 rounded-xl ${\n            activeTab === \'home\' ? \'text-[#ffc174]\' : \'text-[#bcc7de] hover:bg-[#2d3449]/30\'\n          }`}\n        >\n          <Flame className={`w-6 h-6 ${activeTab === \'home\' ? \'fill-[#ffc174]\' : \'\'}`} />\n          <span className=\"font-mono text-[10px] mt-1 font-bold\">Home</span>\n          {activeTab === \'home\' && <span className=\"w-1.5 h-1.5 rounded-full bg-[#ffc174] mt-0.5 animate-pulse\"></span>}\n        </button>\n\n        {/* Tab 2: Events */}\n        <button \n          id=\"tab-events\"\n          onClick={() => setActiveTab(\'events\')}\n          className={`flex flex-col items-center justify-center cursor-pointer transition-all duration-200 px-4 py-1.5 rounded-xl ${\n            activeTab === \'events\' ? \'text-[#ffc174]\' : \'text-[#bcc7de] hover:bg-[#2d3449]/30\'\n          }`}\n        >\n          <Calendar className=\"w-6 h-6\" />\n          <span className=\"font-mono text-[10px] mt-1 font-bold\">Events</span>\n          {activeTab === \'events\' && <span className=\"w-1.5 h-1.5 rounded-full bg-[#ffc174] mt-0.5 animate-pulse\"></span>}\n        </button>\n\n        {/* Tab 3: Check-In QR Button */}\n        <div className=\"flex flex-col items-center justify-center -mb-2\">\n          <button \n            id=\"tab-checkin\"\n            onClick={() => setActiveTab(\'check-in\')}\n            className={`w-14 h-14 rounded-2xl flex items-center justify-center shadow-lg transition-all duration-300 active:scale-90 border-4 border-[#0b1326] ${\n              activeTab === \'check-in\' \n                ? \'bg-gradient-to-br from-[#f59e0b] to-[#ffc174] text-[#472a00] shadow-[#f59e0b]/40 rotate-45\' \n                : \'bg-gradient-to-br from-[#3e495d] to-[#bcc7de] text-[#111c2d]\'\n            }`}\n          >\n            <QrCode className={`w-7 h-7 ${activeTab === \'check-in\' ? \'-rotate-45\' : \'\'}`} />\n          </button>\n          <span className=\"font-mono text-[10px] mt-1.5 font-bold text-[#ffc174]\">Check-In</span>\n        </div>\n\n        {/* Tab 4: Posts */}\n        <button \n          id=\"tab-posts\"\n          onClick={() => setActiveTab(\'posts\')}\n          className={`flex flex-col items-center justify-center cursor-pointer transition-all duration-200 px-4 py-1.5 rounded-xl ${\n            activeTab === \'posts\' ? \'text-[#ffc174]\' : \'text-[#bcc7de] hover:bg-[#2d3449]/30\'\n          }`}\n        >\n          <MessageSquare className=\"w-6 h-6\" />\n          <span className=\"font-mono text-[10px] mt-1 font-bold\">Posts</span>\n          {activeTab === \'posts\' && <span className=\"w-1.5 h-1.5 rounded-full bg-[#ffc174] mt-0.5 animate-pulse\"></span>}\n        </button>\n\n        {/* Tab 5: Prayers */}\n        <button \n          id=\"tab-prayers\"\n          onClick={() => setActiveTab(\'prayers\')}\n          className={`flex flex-col items-center justify-center cursor-pointer transition-all duration-200 px-4 py-1.5 rounded-xl ${\n            activeTab === \'prayers\' ? \'text-[#ffc174]\' : \'text-[#bcc7de] hover:bg-[#2d3449]/30\'\n          }`}\n        >\n          <Heart className=\"w-6 h-6\" />\n          <span className=\"font-mono text-[10px] mt-1 font-bold\">Prayers</span>\n          {activeTab === \'prayers\' && <span className=\"w-1.5 h-1.5 rounded-full bg-[#ffc174] mt-0.5 animate-pulse\"></span>}\n        </button>\n\n      </nav>\n\n    </div>\n  );\n}"
